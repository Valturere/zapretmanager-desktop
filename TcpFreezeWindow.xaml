<Window x:Class="ZapretManager.TcpFreezeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ZapretManager.Controls"
        Title="DPI TCP 16-20"
        Width="1120"
        Height="820"
        MinWidth="980"
        MinHeight="720"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBgBrush" Color="#102235" />
        <SolidColorBrush x:Key="WindowBorderBrush" Color="#295276" />
        <SolidColorBrush x:Key="MainTextBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#9AB2CD" />
        <SolidColorBrush x:Key="CardBrush" Color="#102235" />
        <SolidColorBrush x:Key="CardBrush2" Color="#0C1A28" />
        <SolidColorBrush x:Key="CardEdgeBrush" Color="#2B5377" />
        <SolidColorBrush x:Key="InputBrush" Color="#0C1A28" />
        <SolidColorBrush x:Key="InputBorderBrush" Color="#274A6B" />
        <SolidColorBrush x:Key="ActionBrush" Color="#173454" />
        <SolidColorBrush x:Key="ActionBorderBrush" Color="#31597F" />
        <SolidColorBrush x:Key="ActionHoverBrush" Color="#1E466E" />
        <SolidColorBrush x:Key="SelectionBrush" Color="#395879" />
        <SolidColorBrush x:Key="AccentBrush" Color="#47C78B" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#7BE2B2" />
        <SolidColorBrush x:Key="AccentTextBrush" Color="#0A2416" />
        <SolidColorBrush x:Key="DisabledBrush" Color="#142231" />
        <SolidColorBrush x:Key="DisabledBorderBrush" Color="#21384F" />
        <SolidColorBrush x:Key="DisabledTextBrush" Color="#7C93AA" />
        <SolidColorBrush x:Key="ScrollTrackBrush" Color="#102235" />
        <SolidColorBrush x:Key="ScrollThumbBrush" Color="#4A6A86" />
        <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#5B7C98" />
        <SolidColorBrush x:Key="ProgressTrackBrush" Color="#18324C" />
        <SolidColorBrush x:Key="ProgressFillBrush" Color="#47C78B" />

        <SolidColorBrush x:Key="ProbeBadgeSuccessBackgroundBrush" Color="#27423D" />
        <SolidColorBrush x:Key="ProbeBadgeSuccessBorderBrush" Color="#6C9184" />
        <SolidColorBrush x:Key="ProbeBadgeSuccessForegroundBrush" Color="#7FE0B4" />
        <SolidColorBrush x:Key="ProbeBadgePartialBackgroundBrush" Color="#4A422E" />
        <SolidColorBrush x:Key="ProbeBadgePartialBorderBrush" Color="#A89566" />
        <SolidColorBrush x:Key="ProbeBadgePartialForegroundBrush" Color="#E3C168" />
        <SolidColorBrush x:Key="ProbeBadgeFailureBackgroundBrush" Color="#4F3537" />
        <SolidColorBrush x:Key="ProbeBadgeFailureBorderBrush" Color="#B88484" />
        <SolidColorBrush x:Key="ProbeBadgeFailureForegroundBrush" Color="#E6B3B1" />
        <SolidColorBrush x:Key="ProbeBadgeNeutralBackgroundBrush" Color="#0C1A28" />
        <SolidColorBrush x:Key="ProbeBadgeNeutralBorderBrush" Color="#274A6B" />
        <SolidColorBrush x:Key="ProbeBadgeNeutralForegroundBrush" Color="#9AB2CD" />

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBrush2}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource ActionBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ActionBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MiniIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="MinWidth" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{DynamicResource ActionBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ActionBorderBrush}" />
            <Setter Property="BorderThickness" Value="1.4" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ActionHoverBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource ScrollThumbBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ScrollThumbHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ScrollBarButtonStyle" TargetType="RepeatButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{DynamicResource ScrollTrackBrush}" />
            <Setter Property="Width" Value="4" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   Orientation="{TemplateBinding Orientation}"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarButtonStyle}" Command="ScrollBar.LineUpCommand" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Margin="0" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarButtonStyle}" Command="ScrollBar.LineDownCommand" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="4" />
                    <Setter Property="Width" Value="Auto" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RowBackground" Value="{DynamicResource CardBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource CardBrush2}" />
            <Setter Property="HeadersVisibility" Value="None" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserReorderColumns" Value="False" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="CanUserSortColumns" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource CardBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ActionHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="TextBlock.TextAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource SelectionBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LogTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource CardBrush2}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </Window.Resources>

    <Border Margin="1"
            Background="{DynamicResource WindowBgBrush}"
            BorderBrush="{DynamicResource WindowBorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="18"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.18" Color="#172838" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="DPI TCP 16-20"
                               Foreground="{DynamicResource MainTextBrush}"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="SummaryTextBlock"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="13" />
                </StackPanel>
                <Button Grid.Column="1"
                        Width="34"
                        Height="34"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Foreground="{DynamicResource MainTextBrush}"
                        Click="CloseButton_Click">
                    <Path Data="M13.46 12L19 17.54V19h-1.46L12 13.46L6.46 19H5v-1.46L10.54 12L5 6.46V5h1.46L12 10.54L17.54 5H19v1.46z"
                          Width="14"
                          Height="14"
                          Stretch="Uniform"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Button>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,16,0,14"
                    Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Margin="0,0,18,0">
                        <TextBlock x:Name="StatusTextBlock"
                                   Foreground="{DynamicResource MainTextBrush}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Text="Инструмент готов к запуску." />
                        <TextBlock x:Name="PhaseTextBlock"
                                   Margin="0,6,0,0"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12.5"
                                   TextWrapping="Wrap"
                                   Text="Выберите конфиг в таблице и запустите тест." />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Margin="0,0,12,0"
                            Style="{StaticResource PanelBorderStyle}"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="Целей на конфиг"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="11.5" />
                            <TextBlock x:Name="TargetsMetricTextBlock"
                                       Margin="0,4,0,0"
                                       Foreground="{DynamicResource MainTextBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="-" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Margin="0,0,12,0"
                            Style="{StaticResource PanelBorderStyle}"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="Прогресс"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="11.5" />
                            <TextBlock x:Name="ProgressMetricTextBlock"
                                       Margin="0,4,0,0"
                                       Foreground="{DynamicResource MainTextBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="0 / 0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3"
                            Style="{StaticResource PanelBorderStyle}"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="Лучший конфиг"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="11.5" />
                            <TextBlock x:Name="RecommendedConfigTextBlock"
                                       Margin="0,4,0,0"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="Появится после завершения" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1"
                          Grid.ColumnSpan="4"
                          Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Прогресс проверки"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12.5" />
                        <TextBlock x:Name="ProgressCountTextBlock"
                                   Grid.Column="1"
                                   Margin="12,0,0,0"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Text="0 / 0" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,0,0,14"
                    Padding="14,12"
                    CornerRadius="12"
                    Background="{DynamicResource CardBrush2}"
                    BorderBrush="{DynamicResource InputBorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="280" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,0,0"
                                VerticalAlignment="Top">
                        <TextBlock Text="Выбранный конфиг"
                                   Foreground="{DynamicResource MainTextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="13" />
                        <TextBlock x:Name="SelectedConfigNameTextBlock"
                                   Margin="0,4,0,0"
                                   Foreground="{DynamicResource MainTextBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Text="Конфиг не выбран" />
                        <TextBlock x:Name="SelectedSummaryTextBlock"
                                   Margin="0,6,0,0"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12.5"
                                   Text="Запустите тест, чтобы получить итог по этому конфигу." />
                        <TextBlock x:Name="SelectedBlockedTextBlock"
                                   Margin="0,6,0,0"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12"
                                   Visibility="Collapsed"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Top">
                        <TextBlock x:Name="CurrentTargetTextBlock"
                                   Foreground="{DynamicResource MainTextBrush}"
                                   FontSize="12.5"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Text="Цель ещё не проверяется" />
                        <TextBlock
                                   Margin="0,6,0,0"
                                   Text="Подробные результаты появляются по кнопке у строки конфига."
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource ActionBrush}"
                        BorderBrush="{DynamicResource CardEdgeBrush}"
                        BorderThickness="1,1,1,0"
                        SnapsToDevicePixels="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="84" />
                            <ColumnDefinition Width="84" />
                            <ColumnDefinition Width="84" />
                            <ColumnDefinition Width="84" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                BorderBrush="{DynamicResource CardEdgeBrush}"
                                BorderThickness="0,0,1,1">
                            <TextBlock Text="Конфиг"
                                       Margin="12,8"
                                       Foreground="{DynamicResource MainTextBrush}"
                                       FontWeight="SemiBold" />
                        </Border>
                        <Border Grid.Column="1" BorderBrush="{DynamicResource CardEdgeBrush}" BorderThickness="0,0,1,1">
                            <TextBlock Text="OK" Margin="0,8" HorizontalAlignment="Center" Foreground="{DynamicResource MainTextBrush}" FontWeight="SemiBold" />
                        </Border>
                        <Border Grid.Column="2" BorderBrush="{DynamicResource CardEdgeBrush}" BorderThickness="0,0,1,1">
                            <TextBlock Text="Blocked" Margin="0,8" HorizontalAlignment="Center" Foreground="{DynamicResource MainTextBrush}" FontWeight="SemiBold" />
                        </Border>
                        <Border Grid.Column="3" BorderBrush="{DynamicResource CardEdgeBrush}" BorderThickness="0,0,1,1">
                            <TextBlock Text="Fail" Margin="0,8" HorizontalAlignment="Center" Foreground="{DynamicResource MainTextBrush}" FontWeight="SemiBold" />
                        </Border>
                        <Border Grid.Column="4" BorderBrush="{DynamicResource CardEdgeBrush}" BorderThickness="0,0,1,1">
                            <TextBlock Text="Unsup" Margin="0,8" HorizontalAlignment="Center" Foreground="{DynamicResource MainTextBrush}" FontWeight="SemiBold" />
                        </Border>
                        <Border Grid.Column="5" BorderBrush="{DynamicResource CardEdgeBrush}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Сводка" Margin="12,8" Foreground="{DynamicResource MainTextBrush}" FontWeight="SemiBold" />
                        </Border>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="1"
                          x:Name="ConfigGrid"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          HeadersVisibility="None"
                          BorderThickness="1,0,1,1"
                          SelectionChanged="ConfigGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="280">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="12,3,4,3">
                                        <TextBlock Text="{Binding ConfigName}" Foreground="{DynamicResource MainTextBrush}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding FileName}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11.5" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="84">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <TextBlock Text="{Binding OkText}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="84">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <TextBlock Text="{Binding BlockedText}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="84">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <TextBlock Text="{Binding FailText}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="84">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <TextBlock Text="{Binding UnsupportedText}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Margin="8,0,2,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <DockPanel LastChildFill="True"
                                                   Margin="0,0,4,0">
                                            <controls:ProbeStatusBadge BadgeText="{Binding SummaryBadgeText}"
                                                                       Margin="0,0,8,0"
                                                                       HorizontalAlignment="Left"
                                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding SummaryText}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,2,0" />
                                        </DockPanel>
                                        <Button Grid.Column="1"
                                                Click="DetailsButton_Click"
                                                Tag="{Binding}"
                                                Margin="0,0,8,0"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                ToolTip="Подробные результаты TCP 16-20">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource MiniIconButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding HasResult}" Value="True" />
                                                                <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver}" Value="True" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Path Width="12"
                                                  Height="12"
                                                  Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                                  StrokeThickness="1.45"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Data="M 3 1.8 H 8.4 L 11.2 4.6 V 11.2 H 3 Z M 8.2 1.8 V 4.8 H 11.2 M 5.1 6.6 H 9.2 M 5.1 8.5 H 9.2" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Expander Grid.Row="4"
                      Margin="0,14,0,0"
                      Foreground="{DynamicResource MainTextBrush}"
                      Header="Подробный лог">
                <TextBox x:Name="LogTextBox"
                         Margin="0,10,0,0"
                         Style="{StaticResource LogTextBoxStyle}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         MinHeight="150"
                         MaxHeight="220" />
            </Expander>

            <Grid Grid.Row="5"
                  Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="FooterTextBlock"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="12.5"
                           TextWrapping="Wrap"
                           Margin="0,0,12,0" />

                <Button x:Name="RunSelectedButton"
                        Grid.Column="1"
                        Width="178"
                        Margin="12,0,0,0"
                        Content="Проверить выбранный"
                        Style="{StaticResource ActionButtonStyle}"
                        Click="RunSelectedButton_Click" />

                <Button x:Name="RunAllButton"
                        Grid.Column="2"
                        Width="146"
                        Margin="10,0,0,0"
                        Content="Проверить все"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="RunAllButton_Click" />

                <Button x:Name="ActionButton"
                        Grid.Column="3"
                        Width="112"
                        Margin="10,0,0,0"
                        Content="Закрыть"
                        Style="{StaticResource ActionButtonStyle}"
                        Click="ActionButton_Click" />
            </Grid>
        </Grid>
    </Border>
</Window>
