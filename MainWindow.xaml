                                                  Style="{StaticResource PageHeaderIconPathStyle}"
                                                  Fill="{DynamicResource AccentBorderBrush}"
                                                  Margin="0,0,10,0" />
                                            <TextBlock Text="Настройки" Style="{StaticResource PageHeaderTitleTextStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="Параметры поведения программы и настройки TG WS Proxy."
                                                   Style="{StaticResource PageHeaderDescriptionTextStyle}" />
                                    </StackPanel>
                                </Grid>
                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <Border Style="{StaticResource CardStyle}" MinHeight="178" VerticalAlignment="Top" Margin="0,0,0,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <Path Data="{StaticResource MdiLanConnectGeometry}"
                                                      Style="{StaticResource SectionHeaderIconPathStyle}" />
                                                <TextBlock Text="Поведение" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <TextBlock Text="Тема приложения"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       FontSize="11.5"
                                                       Margin="0,0,0,4" />
                                            <ComboBox ItemsSource="{Binding ApplicationThemeOptions}"
                                                      SelectedItem="{Binding SelectedApplicationThemeMode, Mode=TwoWay}"
                                                      Margin="0,0,0,10" />
                                            <CheckBox Content="При закрытии в трей" IsChecked="{Binding CloseToTrayEnabled, Mode=TwoWay}" />
                                            <CheckBox Content="Автозапуск с Windows" IsChecked="{Binding StartWithWindowsEnabled, Mode=TwoWay}" />
                                            <CheckBox Content="Сворачивать в трей" IsChecked="{Binding MinimizeToTrayEnabled, Mode=TwoWay}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource CardStyle}" MinHeight="188" VerticalAlignment="Top">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <Path Data="{StaticResource MdiRefreshGeometry}"
                                                      Style="{StaticResource SectionHeaderIconPathStyle}" />
                                                <TextBlock Text="Настройка обновлений" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <CheckBox Content="Автопроверка обновлений"
                                                      IsChecked="{Binding AutoCheckUpdatesEnabled, Mode=TwoWay}" />
                                            <TextBlock Text="Проверять обновления"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       FontSize="11.5"
                                                       Margin="0,10,0,4" />
                                            <ComboBox ItemsSource="{Binding UpdateCheckIntervalOptions}"
                                                      SelectedItem="{Binding SelectedUpdateCheckIntervalOption, Mode=TwoWay}"
                                                      IsEnabled="{Binding AutoCheckUpdatesEnabled}"
                                                      Margin="0,0,0,10" />
                                            <CheckBox Content="Автообновление списка IPSet"
                                                      IsChecked="{Binding AutoUpdateIpSetOnStartupEnabled, Mode=TwoWay}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource CardStyle}" MinHeight="320" VerticalAlignment="Top">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource MdiTelegramGeometry}"
                                                  Style="{StaticResource SectionHeaderIconPathStyle}" />
                                            <TextBlock Text="TG WS Proxy: логи и поведение" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Grid.Row="1"
                                                   Text="Эти параметры относятся только к TG WS Proxy и сохраняются в его конфиг."
                                                   Style="{StaticResource MutedTextStyle}" />
                                        <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                            <CheckBox Content="Подробное логирование (verbose)"
                                                      IsChecked="{Binding TgWsProxyVerboseLoggingEnabled, Mode=TwoWay}" />
                                            <TextBlock Text="Буфер, КБ (по умолчанию 256)"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       FontSize="11.5"
                                                       Margin="0,10,0,0" />
                                            <TextBox Margin="0,4,0,0"
                                                     Text="{Binding TgWsProxyBufferKilobytes, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="Пул WebSocket-сессий (по умолчанию 4)"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       FontSize="11.5"
                                                       Margin="0,10,0,0" />
                                            <TextBox Margin="0,4,0,0"
                                                     Text="{Binding TgWsProxyPoolSize, UpdateSourceTrigger=PropertyChanged}" />
                                            <CheckBox Content="Проверять обновления TG WS Proxy через ZapretManager"
                                                      IsChecked="{Binding TgWsProxyAutoCheckUpdatesEnabled, Mode=TwoWay}"
                                                      Margin="0,10,0,0" />
                                            <CheckBox Content="Автозапуск при включении компьютера"
                                                      IsChecked="{Binding TgWsProxyAutoStartEnabled, Mode=TwoWay}"
                                                      Margin="0,6,0,0" />
                                            <TextBlock Text="Макс. размер лога, МБ (по умолчанию 5)"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       FontSize="11.5"
                                                       Margin="0,10,0,0" />
                                            <TextBox Margin="0,4,0,0"
                                                     Text="{Binding TgWsProxyLogMaxMegabytes, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Content="Открыть лог"
                                                    Command="{Binding OpenTgWsProxyLogsCommand}"
                                                    Style="{StaticResource ActionButtonStyle}"
                                                    Margin="0,10,0,0" />
                                            <Button Content="Открыть папку"
                                                    Command="{Binding OpenTgWsProxyFolderCommand}"
                                                    Style="{StaticResource ActionButtonStyle}"
                                                    Margin="0,8,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>

                <Grid Grid.Row="0"
                      Panel.ZIndex="20"
                      Margin="188,0,20,18"
                      IsHitTestVisible="False">
                    <Border MaxWidth="780"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Background="{DynamicResource CardBrush2}"
                            BorderBrush="{DynamicResource CardEdgeBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Opacity="0.92">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowBusyOverlay}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18"
                                              ShadowDepth="0"
                                              Opacity="0.18"
                                              Color="#101B2C" />
                        </Border.Effect>
                        <Grid Margin="14,12,14,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Width="34"
                                    Height="34"
                                    CornerRadius="10"
                                    Background="{DynamicResource CardBrush2}"
                                    BorderBrush="{DynamicResource AccentBorderBrush}"
                                    BorderThickness="1">
                                <Path Data="{StaticResource MdiHistoryGeometry}"
                                      Style="{StaticResource AccentIconPathStyle}"
                                      Fill="{DynamicResource AccentBorderBrush}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{Binding BusyActionText}"
                                           Foreground="{DynamicResource MainTextBrush}"
                                           FontSize="13.6"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,6" />
                                <ProgressBar Height="6"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="{Binding BusyProgressValue}"
                                             IsIndeterminate="{Binding BusyProgressIsIndeterminate}" />
                                <TextBlock Text="{Binding BusyEtaText}"
                                           Margin="0,6,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="0"
                      Panel.ZIndex="26"
                      Margin="188,0,20,108"
                      IsHitTestVisible="False">
                    <Border Padding="12,10"
                            MaxWidth="720"
                            MaxHeight="176"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            CornerRadius="12">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Setter Property="Background" Value="{DynamicResource CardBrush2}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource CardEdgeBrush}" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsInlineNotificationVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsInlineNotificationError}" Value="True">
                                        <Setter Property="Background" Value="#4A2430" />
                                        <Setter Property="BorderBrush" Value="#D08AA8" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding InlineNotificationText}" Foreground="{DynamicResource MainTextBrush}" FontSize="12.6" FontWeight="SemiBold" LineHeight="18" TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
