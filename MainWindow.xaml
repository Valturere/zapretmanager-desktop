                                            </StackPanel>

                                            <Button Command="{Binding AutoInstallCommand}" Style="{StaticResource HomeFeatureButtonStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="12" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0"
                                                            Width="40"
                                                            Height="40"
                                                            CornerRadius="12"
