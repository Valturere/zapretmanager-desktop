                                                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelectedConfigInstalledAsService}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <Path Data="{StaticResource MdiServerGeometry}"
                                                              Style="{StaticResource ButtonIconPathStyle}"
                                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                              Margin="0,0,8,0" />
                                                        <TextBlock Text="Установить службу" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Margin="0"
                                                        MinWidth="0"
                                                        Command="{Binding ToggleSelectedServiceCommand}">
