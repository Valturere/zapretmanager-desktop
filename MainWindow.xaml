                                                                   Text="Использует найденную установку zapret и рекомендуемый конфиг."
                                                                   Style="{StaticResource HomeBodyTextStyle}" />
                                                    </StackPanel>
                                                    <Path Grid.Column="3"
                                                          Data="{StaticResource MdiChevronRightGeometry}"
                                                          Style="{StaticResource AccentIconPathStyle}"
                                                          Fill="{DynamicResource TextMutedBrush}"
                                                          VerticalAlignment="Center" />
                                                </Grid>
                                            </Button>

                                            <Button Command="{Binding AutoConfigureTgWsProxyCommand}" Style="{StaticResource HomeFeatureButtonStyle}" Margin="0,0,0,0">
