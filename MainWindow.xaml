                                                              Style="{StaticResource AccentIconPathStyle}"
                                                              Fill="{DynamicResource AccentBorderBrush}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                                    </Border>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Автоматический режим (zapret)"
                                                                   Foreground="{DynamicResource MainTextBrush}"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold" />
