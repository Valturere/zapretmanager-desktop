                                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                              Margin="0,0,8,0" />
                                                        <TextBlock Text="Удалить службу" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                            <Button Grid.Row="1"
                                                    Grid.Column="1"
                                                    Margin="0"
                                                    MinWidth="0"
                                                    Command="{Binding HideSelectedConfigCommand}"
