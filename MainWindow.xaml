                                        <Button x:Name="TcpRunSelectedButton" Grid.Column="1" Margin="10,0,0,0" MinWidth="168" Content="Проверить выбранный" Style="{StaticResource ActionButtonStyle}" Click="TcpRunSelectedButton_Click" />
                                        <Button x:Name="TcpRunAllButton" Grid.Column="2" Margin="8,0,0,0" MinWidth="132" Content="Проверить все" Style="{StaticResource PrimaryButtonStyle}" Click="TcpRunAllButton_Click" />
                                    </Grid>
                                </Border>

