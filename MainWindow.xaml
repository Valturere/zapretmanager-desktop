                                            <Button Grid.Column="2" Margin="8,0,0,0" MinWidth="132" Content="{Binding ProbeButtonText}" Command="{Binding RunTestsCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

