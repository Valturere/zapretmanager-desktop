        </Style>

        <Style x:Key="PageHeaderDescriptionTextStyle" TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <Style x:Key="HomeOverallStatusPathStyle" TargetType="Path">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="Data" Value="{StaticResource MdiCheckGeometry}" />
            <Style.Triggers>
                <Trigger Property="Tag" Value="missing">
                    <Setter Property="Data" Value="{StaticResource MdiAlertCircleGeometry}" />
                </Trigger>
                <Trigger Property="Tag" Value="warning">
                    <Setter Property="Data" Value="{StaticResource MdiAlertCircleGeometry}" />
                </Trigger>
                <Trigger Property="Tag" Value="available">
                    <Setter Property="Data" Value="{StaticResource MdiRefreshGeometry}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HomeRecommendedActionPathStyle" TargetType="Path">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="Data" Value="{StaticResource MdiInfoGeometry}" />
            <Style.Triggers>
                <Trigger Property="Tag" Value="install-zapret">
                    <Setter Property="Data" Value="{StaticResource MdiDownloadGeometry}" />
                </Trigger>
                <Trigger Property="Tag" Value="busy">
                    <Setter Property="Data" Value="{StaticResource MdiHistoryGeometry}" />
                </Trigger>
                <Trigger Property="Tag" Value="test-configs">
                    <Setter Property="Data" Value="{StaticResource MdiRefreshGeometry}" />
                </Trigger>
                <Trigger Property="Tag" Value="review-configs">
                    <Setter Property="Data" Value="{StaticResource MdiListBulletedGeometry}" />
                </Trigger>
                <Trigger Property="Tag" Value="start-recommended">
                    <Setter Property="Data" Value="{StaticResource MdiPlayGeometry}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HomeStatusChipIconPathStyle" TargetType="Path" BasedOn="{StaticResource ButtonIconPathStyle}">
            <Setter Property="Fill" Value="{DynamicResource TextMutedBrush}" />
            <Style.Triggers>
                <Trigger Property="Tag" Value="ok">
                    <Setter Property="Fill" Value="{DynamicResource SummarySuccessBadgeIconBrush}" />
                </Trigger>
                <Trigger Property="Tag" Value="available">
                    <Setter Property="Fill" Value="{DynamicResource InstallAvailableBadgeForegroundBrush}" />
                </Trigger>
                <Trigger Property="Tag" Value="warning">
                    <Setter Property="Fill" Value="{DynamicResource SummaryPartialBadgeIconBrush}" />
                </Trigger>
                <Trigger Property="Tag" Value="missing">
                    <Setter Property="Fill" Value="{DynamicResource SummaryFailureBadgeIconBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InstallStatusBadgeIconPathStyle" TargetType="Path" BasedOn="{StaticResource ButtonIconPathStyle}">
            <Setter Property="Fill" Value="{DynamicResource InstallAvailableBadgeForegroundBrush}" />
            <Style.Triggers>
                <Trigger Property="Tag" Value="ok">
                    <Setter Property="Fill" Value="{DynamicResource SummarySuccessBadgeIconBrush}" />
                </Trigger>
                <Trigger Property="Tag" Value="available">
                    <Setter Property="Fill" Value="{DynamicResource InstallAvailableBadgeForegroundBrush}" />
                </Trigger>
                <Trigger Property="Tag" Value="unchecked">
                    <Setter Property="Fill" Value="{DynamicResource InstallAvailableBadgeForegroundBrush}" />
                </Trigger>
                <Trigger Property="Tag" Value="missing">
                    <Setter Property="Fill" Value="{DynamicResource SummaryFailureBadgeIconBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarLabelTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Width" Value="118" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" />
            <Setter Property="Visibility" Value="Visible" />
        </Style>

        <Style x:Key="SidebarFooterLinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" CornerRadius="6">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBorderBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ThemeToggleCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Width" Value="86" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                            <Border x:Name="Track"
                                    CornerRadius="20"
                                    Background="{DynamicResource ActionBrush}"
                                    BorderBrush="{DynamicResource CardEdgeBrush}"
                                    BorderThickness="1" />
                            <Path x:Name="SunGlyph"
                                  Data="{StaticResource MdiThemeSunGeometry}"
                                  Width="16"
                                  Height="16"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  Margin="14,0,0,0"
                                  Fill="{DynamicResource TextMutedBrush}" />
                            <Path x:Name="MoonGlyph"
                                  Data="{StaticResource MdiThemeMoonGeometry}"
                                  Width="16"
                                  Height="16"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,14,0"
                                  Fill="{DynamicResource MainTextBrush}" />
                            <Border x:Name="Thumb"
                                    Width="28"
                                    Height="28"
                                    CornerRadius="14"
                                    Background="{DynamicResource MainTextBrush}"
                                    HorizontalAlignment="Left"
                                    Margin="6,6,0,6" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#EAF1FF" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="#BBD0FF" />
                                <Setter TargetName="SunGlyph" Property="Fill" Value="#D78B0C" />
                                <Setter TargetName="MoonGlyph" Property="Fill" Value="#7A8FAA" />
                                <Setter TargetName="Thumb" Property="Background" Value="#0B1322" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,6,6,6" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource ActionBrush}" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource CardEdgeBrush}" />
                                <Setter TargetName="SunGlyph" Property="Fill" Value="{DynamicResource TextMutedBrush}" />
                                <Setter TargetName="MoonGlyph" Property="Fill" Value="{DynamicResource MainTextBrush}" />
                                <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource MainTextBrush}" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Left" />
                                <Setter TargetName="Thumb" Property="Margin" Value="6,6,0,6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="WindowRootBorder"
            Background="{DynamicResource AppBgBrush}"
            BorderBrush="{DynamicResource CardEdgeBrush}"
            BorderThickness="1"
            CornerRadius="14"
            ClipToBounds="True"
            SnapsToDevicePixels="True">
        <Grid x:Name="WindowRootGrid"
              Margin="0"
              Focusable="True"
              PreviewMouseDown="WindowRootGrid_PreviewMouseDown">
            <Grid.RowDefinitions>
                <RowDefinition Height="52" />
                <RowDefinition Height="0" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource TitleBarBrush}"
                    BorderBrush="{DynamicResource CardEdgeBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="18,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                        <Border Width="28"
                                Height="28"
                                CornerRadius="8"
                                Background="{DynamicResource AccentBrush}"
                                BorderBrush="{DynamicResource AccentBorderBrush}"
                                BorderThickness="1">
                            <Image Width="18" Height="18" Source="Assets/zapret-manager.ico" Stretch="Uniform" />
                        </Border>
                        <TextBlock Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource MainTextBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Text="{Binding WindowTitle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,6,16,6">
                        <TextBlock Margin="0,0,12,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11.5"
                                   Text="{Binding ManagerVersionLabel}" />
                        <Border Background="{DynamicResource CardBrush}"
                                BorderBrush="{DynamicResource CardEdgeBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                ClipToBounds="True">
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource WindowControlButtonStyle}" Click="MinimizeButton_Click" ToolTip="Свернуть окно">
                                    <Path Data="{StaticResource MdiWindowMinimizeGeometry}"
                                          Style="{StaticResource TitleBarIconPathStyle}"
                                          Fill="{DynamicResource MainTextBrush}" />
                                </Button>
                                <Button Style="{StaticResource WindowControlButtonStyle}" Click="CloseButton_Click" ToolTip="Закрыть окно">
                                    <Path Data="{StaticResource MdiWindowCloseGeometry}"
                                          Style="{StaticResource TitleBarIconPathStyle}"
                                          Fill="{DynamicResource MainTextBrush}" />
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Visibility="Collapsed"
                    Background="{DynamicResource CardBrush2}"
                    BorderBrush="{DynamicResource CardEdgeBrush}"
                    BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" Margin="12,3,0,3">
                    <Button Content="Списки"
                            Style="{StaticResource MenuHostButtonStyle}"
                            Click="MenuHostButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="Включённые домены" Command="{Binding OpenIncludedDomainsEditorCommand}" />
                                <MenuItem Header="Исключённые домены" Command="{Binding OpenExcludedDomainsEditorCommand}" />
                                <MenuItem Header="Системный hosts" Command="{Binding OpenHostsEditorCommand}" />
                                <MenuItem Header="Домены для проверки" Command="{Binding OpenTargetsFileCommand}" />
                                <Separator />
                                <MenuItem Header="Скрытые конфиги..." Command="{Binding OpenHiddenConfigsCommand}" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <Button Content="Инструменты"
                            Style="{StaticResource MenuHostButtonStyle}"
                            Click="MenuHostButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="Диагностика системы..." Command="{Binding OpenDiagnosticsCommand}" />
                                <MenuItem Header="DPI TCP 16-20..." Command="{Binding OpenTcpFreezeToolCommand}" />
                                <MenuItem Header="Обновить список IPSet" Command="{Binding UpdateIpSetListCommand}" />
                                <MenuItem Header="Обновить hosts для zapret" Command="{Binding UpdateHostsFileCommand}" />
                                <Separator />
                                <MenuItem Header="Очистить кэш Discord" Command="{Binding ClearDiscordCacheCommand}" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <Button Content="Настройки"
                            Style="{StaticResource MenuHostButtonStyle}"
                            Click="MenuHostButton_Click"
                            ToolTip="Настройки автозапуска, трея и обновлений.">
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="Автопроверка обновлений"
                                          IsCheckable="True"
                                          StaysOpenOnClick="True"
                                          IsChecked="{Binding AutoCheckUpdatesEnabled, Mode=TwoWay}" />
                                <MenuItem Header="При закрытии в трей"
                                          IsCheckable="True"
                                          StaysOpenOnClick="True"
                                          IsChecked="{Binding CloseToTrayEnabled, Mode=TwoWay}" />
                                <MenuItem Header="Автозапуск с Windows"
                                          IsCheckable="True"
                                          StaysOpenOnClick="True"
                                          IsChecked="{Binding StartWithWindowsEnabled, Mode=TwoWay}" />
                                <MenuItem Header="Сворачивать в трей"
                                          IsCheckable="True"
                                          StaysOpenOnClick="True"
                                          IsChecked="{Binding MinimizeToTrayEnabled, Mode=TwoWay}" />
                                <Separator />
                                <MenuItem Header="Откатить сборку"
                                          Command="{Binding RestorePreviousVersionCommand}" />
                                <MenuItem Header="Проверить обновление программы"
                                          Command="{Binding CheckManagerUpdateCommand}" />
                                <MenuItem Header="Удалить программу"
                                          Command="{Binding UninstallProgramCommand}" />
                                <Separator />
                                <MenuItem Header="О программе..."
                                          Command="{Binding OpenAboutCommand}" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>
            </Border>

            <Grid Grid.Row="2" Margin="16" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Сборка" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="{Binding InstallationPath}" Style="{StaticResource MutedTextStyle}" />
                            <Grid Margin="0,14,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button Grid.Row="0" Grid.Column="0" Content="Обновить" Margin="0" MinWidth="0" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButtonStyle}" ToolTip="Перечитать текущую папку zapret и обновить статусы." />
                                <Button Grid.Row="0" Grid.Column="2" Content="Поиск zapret" Margin="0" MinWidth="0" Command="{Binding QuickSearchCommand}" Style="{StaticResource ActionButtonStyle}" ToolTip="Быстро найти zapret в типичных местах на компьютере." />
                                <Button Grid.Row="2" Grid.Column="0" Content="Выбрать папку" Margin="0" MinWidth="0" Command="{Binding BrowseCommand}" Style="{StaticResource ActionButtonStyle}" ToolTip="Выбрать рабочую папку zapret вручную." />
                                <Button Grid.Row="2" Grid.Column="2" Content="Открыть" Margin="0" MinWidth="0" Command="{Binding OpenFolderCommand}" Style="{StaticResource ActionButtonStyle}" ToolTip="Открыть текущую папку zapret в проводнике." />
                                <Button Grid.Row="4" Grid.Column="0" Content="Скачать zapret" Margin="0" MinWidth="0" Command="{Binding DownloadZapretCommand}" Style="{StaticResource ActionButtonStyle}" ToolTip="Скачать свежую сборку zapret в выбранную папку." />
                    <Button Grid.Row="4" Grid.Column="2" Content="Удалить zapret" Margin="0" MinWidth="0" Command="{Binding DeleteZapretCommand}" Style="{StaticResource ActionButtonStyle}">
                        <Button.ToolTip>
                            <ToolTip MaxWidth="260">
                                <TextBlock TextWrapping="Wrap"
                                           MaxWidth="240"
                                           LineHeight="15"
                                           Text="Остановить процессы, удалить службу и удалить текущую и предыдущую сборку zapret." />
                            </ToolTip>
                        </Button.ToolTip>
                    </Button>
                                <Button Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3" Content="Автоматический режим" Margin="0" MinWidth="0" Command="{Binding AutoInstallCommand}" Style="{StaticResource PrimaryButtonStyle}">
                                    <Button.ToolTip>
                                        <ToolTip MaxWidth="260">
                                            <TextBlock TextWrapping="Wrap"
                                                       MaxWidth="240"
                                                       LineHeight="15"
                                                       Text="Если сборка уже выбрана, программа проверит конфиги и поставит лучший вариант как службу. Если сборки нет, сначала скачает свежий zapret." />
                                        </ToolTip>
                                    </Button.ToolTip>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Состояние" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="{Binding VersionText}" Foreground="{DynamicResource MainTextBrush}" FontSize="14" FontWeight="SemiBold" />
                            <TextBlock Margin="0,6,0,0" Text="{Binding RuntimeStatus}" Style="{StaticResource MutedTextStyle}" />
                            <TextBlock Margin="0,3,0,0" Text="{Binding ServiceStatus}" Style="{StaticResource MutedTextStyle}" />
                            <TextBlock Margin="0,3,0,0" Text="{Binding UpdateStatus}" Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Panel.ZIndex="20"
                            Margin="12"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource InputBorderBrush}"
                            BorderThickness="2"
                            CornerRadius="14"
                            Opacity="0.985"
                            IsHitTestVisible="False">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20"
                                              ShadowDepth="0"
                                              Opacity="0.2"
                                              Color="#203347" />
                        </Border.Effect>
                        <StackPanel Margin="14,12,14,14">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Border Width="10"
                                        Height="10"
                                        CornerRadius="5"
                                        Background="{DynamicResource AccentBrush}"
                                        BorderBrush="{DynamicResource AccentHoverBrush}"
                                        BorderThickness="1"
                                        Margin="0,0,8,0" />
                                <TextBlock Text="Идёт операция"
                                           Foreground="{DynamicResource MainTextBrush}"
                                           FontSize="14.5"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                            <ProgressBar Margin="0,12,0,12"
                                         Height="7"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="{Binding BusyProgressValue}"
                                         IsIndeterminate="{Binding BusyProgressIsIndeterminate}" />
                            <TextBlock Text="{Binding BusyActionText}"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,0,0,6" />
                            <TextBlock Text="{Binding BusyEtaText}"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,0,0,6" />
                            <TextBlock Text="{Binding RuntimeStatus}"
                                       Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="4" Style="{StaticResource CardStyle}" Padding="16,14,16,14">
                        <Grid>
                            <StackPanel>
                            <TextBlock Text="Служба и обновление" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="Служба"
                                       Foreground="{DynamicResource MainTextBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6" />

                            <UniformGrid Columns="2" Margin="0,0,0,8">
                                <Button Content="Установить службу"
                                        Margin="0"
                                        MinWidth="0"
                                        Command="{Binding InstallServiceCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        ToolTip="Установить выбранный конфиг&#10;как службу Windows с автозапуском." />
                                <Button Content="Удалить службу"
                                        Margin="8,0,0,0"
                                        MinWidth="0"
                                        Command="{Binding RemoveServiceCommand}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        ToolTip="Удалить службу zapret&#10;и остановить её, если она запущена." />
                            </UniformGrid>

                            <Rectangle Height="1" Fill="{DynamicResource CardEdgeBrush}" Margin="0,6,0,8" />

                            <TextBlock Text="Обновление"
                                       Foreground="{DynamicResource MainTextBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6" />

                            <Grid Margin="0,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Row="0"
                                        Grid.Column="0"
                                        Content="Проверить обновл."
                                        Margin="0"
                                        MinWidth="0"
                                        Command="{Binding CheckUpdatesCommand}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        ToolTip="Проверить, вышла ли новая версия сборки." />
                                <Button Grid.Row="0"
                                        Grid.Column="1"
                                        Content="Обновить сборку"
                                        Margin="8,0,0,0"
                                        MinWidth="0"
                                        Command="{Binding ApplyUpdateCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        ToolTip="Скачать и установить новую версию сборки." />
                            </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="4"
                            Panel.ZIndex="26"
                            Margin="12,0,12,12"
                            Padding="12,10"
                            MaxHeight="176"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Bottom"
                            CornerRadius="12"
                            IsHitTestVisible="False">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Setter Property="Background" Value="{DynamicResource CardBrush2}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource CardEdgeBrush}" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsInlineNotificationVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsInlineNotificationError}" Value="True">
                                        <Setter Property="Background" Value="#4A2430" />
                                        <Setter Property="BorderBrush" Value="#D08AA8" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    CornerRadius="2"
                                    Background="{DynamicResource AccentBrush}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInlineNotificationError}" Value="True">
                                                <Setter Property="Background" Value="#E08CAD" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>

                            <ScrollViewer Grid.Column="2"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          CanContentScroll="True">
                                <TextBlock Text="{Binding InlineNotificationText}"
                                           Foreground="{DynamicResource MainTextBrush}"
                                           FontSize="12.6"
                                           FontWeight="SemiBold"
                                           LineHeight="18"
                                           TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Проверка конфигов" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="Один общий список конфигов. Проверка считает сайты из targets.txt, а ping остаётся как отдельная диагностика."
                                       Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>

                        <Border Grid.Row="1"
                                Margin="0,14,0,14"
                                Padding="14"
                                CornerRadius="12"
                                Background="{DynamicResource CardBrush2}"
                                BorderBrush="{DynamicResource InputBorderBrush}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Быстрые цели" Foreground="{DynamicResource MainTextBrush}" FontWeight="SemiBold" FontSize="13" />
                                <WrapPanel Margin="0,12,0,6">
                                        <Button Content="Все цели" Command="{Binding UseDefaultTargetsCommand}" Style="{StaticResource PresetButtonStyle}" ToolTip="Проверять все стандартные адреса из targets.txt." />
                                        <Button Content="YouTube" Command="{Binding UseYouTubePresetCommand}" Style="{StaticResource PresetButtonStyle}" />
                                        <Button Content="Discord" Command="{Binding UseDiscordPresetCommand}" Style="{StaticResource PresetButtonStyle}" />
                                        <Button Content="Cloudflare" Command="{Binding UseCloudflarePresetCommand}" Style="{StaticResource PresetButtonStyle}" />
                                </WrapPanel>
                                <TextBlock Text="{Binding DefaultTargetsHint}" Style="{StaticResource MutedTextStyle}" />
                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <TextBox x:Name="LegacyManualTargetTextBox"
                                                 LostKeyboardFocus="ManualTargetTextBox_LostKeyboardFocus"
                                                 Text="{Binding ManualTarget, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Можно указать свои домены или URL через запятую." />
                                        <TextBlock Margin="12,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   IsHitTestVisible="False"
                                                   Text="Все цели">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ManualTarget}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ManualTarget}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ElementName=LegacyManualTargetTextBox, Path=IsKeyboardFocused}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <Button Grid.Column="1"
                                            Margin="10,0,0,0"
                                            MinWidth="176"
                                            Content="Проверить выбранный"
                                            Command="{Binding RunSelectedTestCommand}"
                                            Style="{StaticResource ActionButtonStyle}"
                                            ToolTip="Проверить только выбранный в таблице конфиг&#10;по выбранным адресам." />
                                    <Button Grid.Column="2"
                                            Margin="8,0,0,0"
                                            MinWidth="140"
                                            Content="{Binding ProbeButtonText}"
                                            Command="{Binding RunTestsCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            ToolTip="Запустить проверку всех видимых конфигов&#10;по выбранным адресам." />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2"
                                Margin="0,0,0,14"
                                Padding="12"
                                CornerRadius="12"
                                Background="{DynamicResource InnerCardBrush}"
                                BorderBrush="{DynamicResource InnerCardBorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,18,0" VerticalAlignment="Center">
                            <TextBlock Text="Результат" Foreground="{DynamicResource MainTextBrush}" FontWeight="SemiBold" FontSize="13" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding RecommendedConfigText}"
                                       Foreground="{DynamicResource AccentBrush}"
                                               FontSize="14"
                                               FontWeight="SemiBold" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding SelectedConfig.Name, TargetNullValue=Конфиг не выбран}"
                                       Foreground="{DynamicResource MainTextBrush}"
                                               FontSize="13"
                                               FontWeight="SemiBold" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding SelectedSummaryText}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                               FontSize="12.5"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <UniformGrid Grid.Column="1" Columns="3" VerticalAlignment="Center">
                                    <Button Content="Запустить выбранный"
                                            Margin="0,0,10,0"
                                            MinWidth="0"
                                            Command="{Binding StartCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            ToolTip="Запустить выбранный конфиг скрыто, без cmd-окна." />
                                    <Button Content="Остановить"
                                            Margin="0,0,10,0"
                                            MinWidth="0"
                                            Command="{Binding StopCommand}"
                                            Style="{StaticResource ActionButtonStyle}"
                                            ToolTip="Остановить вручную запущенный профиль.&#10;Установленная служба этой кнопкой не трогается." />
                                    <Button Content="Скрыть выбранный"
                                            Margin="0,0,0,0"
                                            MinWidth="0"
                                            Command="{Binding HideSelectedConfigCommand}"
                                            Style="{StaticResource ActionButtonStyle}"
                                            ToolTip="Убрать выбранный конфиг из основного списка&#10;и исключить его из проверки." />
                                </UniformGrid>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="{DynamicResource ActionBrush}"
                                    BorderBrush="{DynamicResource CardEdgeBrush}"
                                    BorderThickness="1,1,1,0"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="270" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            BorderBrush="{DynamicResource CardEdgeBrush}"
                                            BorderThickness="0,0,1,1">
                                        <Button Content="Конфиг"
                                                Tag="ConfigName"
                                                Click="ConfigHeaderSortButton_Click"
                                                Style="{StaticResource ConfigHeaderButtonStyle}" />
                                    </Border>
                                    <Border Grid.Column="1"
                                            BorderBrush="{DynamicResource CardEdgeBrush}"
                                            BorderThickness="0,0,1,1">
                                        <Button Content="Доступно"
                                                Tag="SortSuccessValue"
                                                Click="ConfigHeaderSortButton_Click"
                                                HorizontalContentAlignment="Center"
                                                Style="{StaticResource ConfigHeaderButtonStyle}" />
                                    </Border>
                                    <Border Grid.Column="2"
                                            BorderBrush="{DynamicResource CardEdgeBrush}"
                                            BorderThickness="0,0,1,1">
                                        <Button Content="Отклик, мс"
                                                Tag="AveragePingMilliseconds"
                                                Click="ConfigHeaderSortButton_Click"
                                                HorizontalContentAlignment="Center"
                                                Style="{StaticResource ConfigHeaderButtonStyle}" />
                                    </Border>
                                    <Border Grid.Column="3"
                                            BorderBrush="{DynamicResource CardEdgeBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Button Content="Сводка"
                                                Tag="Summary"
                                                Click="ConfigHeaderSortButton_Click"
                                                Style="{StaticResource ConfigHeaderButtonStyle}" />
                                    </Border>
                                </Grid>
                            </Border>

                            <DataGrid Grid.Row="1"
                                      x:Name="LegacyConfigGrid"
                                      ItemsSource="{Binding ConfigRows}"
                                      SelectedItem="{Binding SelectedConfigRow}"
                                      SelectionMode="Extended"
                                      SelectionUnit="FullRow"
                                      SelectionChanged="ConfigGrid_SelectionChanged"
                                      CanUserResizeColumns="False"
                                      HeadersVisibility="None"
                                      BorderThickness="1,0,1,1"
                                      Sorting="ConfigGrid_Sorting">
                                <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Конфиг" Width="270" SortMemberPath="ConfigName">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="12,3,4,3">
                        <TextBlock Text="{Binding ConfigName}" Foreground="{DynamicResource MainTextBrush}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding FileName}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11.5" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Доступно"
                                                        Width="110"
                                                        SortMemberPath="SortSuccessValue">
                                    <DataGridTemplateColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                                        </Style>
                                    </DataGridTemplateColumn.HeaderStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <TextBlock Text="{Binding SuccessCountText}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           TextAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Отклик, мс"
                                                        Width="110"
                                                        SortMemberPath="AveragePingMilliseconds">
                                    <DataGridTemplateColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                                        </Style>
                                    </DataGridTemplateColumn.HeaderStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <TextBlock Text="{Binding ResponseText}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           TextAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Сводка" Width="*" SortMemberPath="Summary">
                                    <DataGridTemplateColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        </Style>
                                    </DataGridTemplateColumn.HeaderStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid Margin="8,0,2,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <DockPanel LastChildFill="True"
                                                           Margin="0,0,4,0">
                                                <controls:ProbeStatusBadge BadgeText="{Binding SummaryBadgeText}"
                                                                           Margin="0,0,8,0"
                                                                           HorizontalAlignment="Left"
                                                                           VerticalAlignment="Center">
                                                    <controls:ProbeStatusBadge.Style>
                                                        <Style TargetType="controls:ProbeStatusBadge">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasProbeResult}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </controls:ProbeStatusBadge.Style>
                                                </controls:ProbeStatusBadge>
                                                <TextBlock Text="{Binding SummaryBodyText}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,2,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SummaryBodyText}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                </DockPanel>
                                                <Button Grid.Column="1"
                                                        Click="ProbeDetailsButton_Click"
                                                        Tag="{Binding}"
                                                        Margin="0,0,8,0"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        ToolTip="Подробные результаты проверки">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource MiniIconButtonStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding HasProbeResult}" Value="True" />
                                                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver}" Value="True" />
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <Path Width="12"
                                                          Height="12"
                                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                                          StrokeThickness="1.45"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          StrokeLineJoin="Round"
                                                          Data="M 3 1.8 H 8.4 L 11.2 4.6 V 11.2 H 3 Z M 8.2 1.8 V 4.8 H 11.2 M 5.1 6.6 H 9.2 M 5.1 8.5 H 9.2" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>
                </Border>

            </Grid>

            <Grid Grid.Row="2"
                  Panel.ZIndex="100"
                  Background="{DynamicResource AppBgBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TabControl x:Name="MainSidebarTabControl" Grid.Row="0" Style="{StaticResource SidebarTabControlStyle}">
                    <TabItem x:Name="HomeTabItem" Style="{StaticResource SidebarTabItemStyle}" IsSelected="True">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource MdiHomeGeometry}"
                                      Style="{StaticResource SidebarIconPathStyle}"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" />
                                <TextBlock Text="Главная" Style="{StaticResource SidebarLabelTextStyle}" />
                            </StackPanel>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid Margin="14,12,14,14">
                                <Grid.Resources>
                                    <Style x:Key="HomeEyebrowTextStyle" TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
                                        <Setter Property="FontSize" Value="13" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Style>
                                    <Style x:Key="HomeHeroTitleStyle" TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource SummarySuccessBadgeIconBrush}" />
                                        <Setter Property="FontSize" Value="22" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Style.Triggers>
                                            <Trigger Property="Tag" Value="available">
                                                <Setter Property="Foreground" Value="{DynamicResource InstallAvailableBadgeForegroundBrush}" />
                                            </Trigger>
                                            <Trigger Property="Tag" Value="warning">
                                                <Setter Property="Foreground" Value="{DynamicResource SummaryPartialBadgeIconBrush}" />
                                            </Trigger>
                                            <Trigger Property="Tag" Value="missing">
                                                <Setter Property="Foreground" Value="{DynamicResource SummaryFailureBadgeIconBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style x:Key="HomeSectionCardTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleStyle}">
                                        <Setter Property="FontSize" Value="15" />
                                        <Setter Property="Margin" Value="0" />
                                    </Style>
                                    <Style x:Key="HomeBodyTextStyle" TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
                                        <Setter Property="FontSize" Value="12.5" />
                                        <Setter Property="LineHeight" Value="18" />
                                    </Style>
                                    <Style x:Key="HomeStatusIconTileStyle" TargetType="Border">
                                        <Setter Property="Width" Value="50" />
                                        <Setter Property="Height" Value="50" />
                                        <Setter Property="CornerRadius" Value="14" />
                                        <Setter Property="Background" Value="{DynamicResource SummarySuccessBadgeBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource SummarySuccessBadgeBorderBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <Trigger Property="Tag" Value="available">
                                                <Setter Property="Background" Value="{DynamicResource InstallAvailableBadgeBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource InstallAvailableBadgeBorderBrush}" />
                                            </Trigger>
                                            <Trigger Property="Tag" Value="warning">
                                                <Setter Property="Background" Value="{DynamicResource SummaryPartialBadgeBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource SummaryPartialBadgeBorderBrush}" />
                                            </Trigger>
                                            <Trigger Property="Tag" Value="missing">
                                                <Setter Property="Background" Value="{DynamicResource SummaryFailureBadgeBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource SummaryFailureBadgeBorderBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style x:Key="HomeOverallStatusIconBrushStyle" TargetType="Path" BasedOn="{StaticResource HomeOverallStatusPathStyle}">
                                        <Setter Property="Fill" Value="{DynamicResource SummarySuccessBadgeIconBrush}" />
                                        <Style.Triggers>
                                            <Trigger Property="Tag" Value="available">
                                                <Setter Property="Fill" Value="{DynamicResource InstallAvailableBadgeForegroundBrush}" />
                                            </Trigger>
                                            <Trigger Property="Tag" Value="warning">
                                                <Setter Property="Fill" Value="{DynamicResource SummaryPartialBadgeIconBrush}" />
                                            </Trigger>
                                            <Trigger Property="Tag" Value="missing">
                                                <Setter Property="Fill" Value="{DynamicResource SummaryFailureBadgeIconBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style x:Key="HomeStatusChipStyle" TargetType="Border">
                                        <Setter Property="Padding" Value="10,4" />
                                        <Setter Property="Margin" Value="0,0,8,6" />
                                        <Setter Property="CornerRadius" Value="8" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="Background" Value="{DynamicResource ActionBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource ActionBorderBrush}" />
                                        <Setter Property="TextElement.Foreground" Value="{DynamicResource TextMutedBrush}" />
                                        <Style.Triggers>
                                            <Trigger Property="Tag" Value="ok">
                                                <Setter Property="Background" Value="{DynamicResource SummarySuccessBadgeBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource SummarySuccessBadgeBorderBrush}" />
                                                <Setter Property="TextElement.Foreground" Value="{DynamicResource SummarySuccessBadgeIconBrush}" />
                                            </Trigger>
                                            <Trigger Property="Tag" Value="available">
                                                <Setter Property="Background" Value="{DynamicResource InstallAvailableBadgeBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource InstallAvailableBadgeBorderBrush}" />
                                                <Setter Property="TextElement.Foreground" Value="{DynamicResource InstallAvailableBadgeForegroundBrush}" />
                                            </Trigger>
                                            <Trigger Property="Tag" Value="warning">
                                                <Setter Property="Background" Value="{DynamicResource SummaryPartialBadgeBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource SummaryPartialBadgeBorderBrush}" />
                                                <Setter Property="TextElement.Foreground" Value="{DynamicResource SummaryPartialBadgeIconBrush}" />
                                            </Trigger>
                                            <Trigger Property="Tag" Value="missing">
                                                <Setter Property="Background" Value="{DynamicResource SummaryFailureBadgeBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource SummaryFailureBadgeBorderBrush}" />
                                                <Setter Property="TextElement.Foreground" Value="{DynamicResource SummaryFailureBadgeIconBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style x:Key="HomeStatusChipButtonStyle" TargetType="Button">
                                        <Setter Property="Padding" Value="10,4" />
                                        <Setter Property="Margin" Value="0,0,8,6" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="Background" Value="{DynamicResource ActionBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource ActionBorderBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                        <Setter Property="HorizontalContentAlignment" Value="Left" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="ChipBorder"
                                                            Padding="{TemplateBinding Padding}"
                                                            CornerRadius="8"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}">
                                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                          VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ChipBorder" Property="Opacity" Value="0.9" />
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="ChipBorder" Property="Opacity" Value="0.82" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="Tag" Value="ok">
                                                <Setter Property="Background" Value="{DynamicResource SummarySuccessBadgeBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource SummarySuccessBadgeBorderBrush}" />
                                                <Setter Property="Foreground" Value="{DynamicResource SummarySuccessBadgeIconBrush}" />
                                            </Trigger>
                                            <Trigger Property="Tag" Value="available">
                                                <Setter Property="Background" Value="{DynamicResource InstallAvailableBadgeBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource InstallAvailableBadgeBorderBrush}" />
                                                <Setter Property="Foreground" Value="{DynamicResource InstallAvailableBadgeForegroundBrush}" />
                                            </Trigger>
                                            <Trigger Property="Tag" Value="warning">
                                                <Setter Property="Background" Value="{DynamicResource SummaryPartialBadgeBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource SummaryPartialBadgeBorderBrush}" />
                                                <Setter Property="Foreground" Value="{DynamicResource SummaryPartialBadgeIconBrush}" />
                                            </Trigger>
                                            <Trigger Property="Tag" Value="missing">
                                                <Setter Property="Background" Value="{DynamicResource SummaryFailureBadgeBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource SummaryFailureBadgeBorderBrush}" />
                                                <Setter Property="Foreground" Value="{DynamicResource SummaryFailureBadgeIconBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style x:Key="HomeFeatureButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                        <Setter Property="Height" Value="Auto" />
                                        <Setter Property="MinWidth" Value="0" />
                                        <Setter Property="Padding" Value="12,10" />
                                        <Setter Property="Margin" Value="0,0,0,6" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="HomeFeatureBorder"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Stretch"
                                                                          VerticalAlignment="Center"
                                                                          Margin="{TemplateBinding Padding}" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="HomeFeatureBorder" Property="Opacity" Value="0.92" />
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="HomeFeatureBorder" Property="Background" Value="{DynamicResource DisabledBrush}" />
                                                            <Setter TargetName="HomeFeatureBorder" Property="BorderBrush" Value="{DynamicResource DisabledBorderBrush}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                    <Style x:Key="HomeFeaturePrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                        <Setter Property="Height" Value="Auto" />
                                        <Setter Property="MinWidth" Value="0" />
                                        <Setter Property="Padding" Value="12,10" />
                                        <Setter Property="Margin" Value="0,0,0,6" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="HomeFeaturePrimaryBorder"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Stretch"
                                                                          VerticalAlignment="Center"
                                                                          Margin="{TemplateBinding Padding}" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="HomeFeaturePrimaryBorder" Property="Opacity" Value="0.92" />
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="HomeFeaturePrimaryBorder" Property="Background" Value="{DynamicResource DisabledBrush}" />
                                                            <Setter TargetName="HomeFeaturePrimaryBorder" Property="BorderBrush" Value="{DynamicResource DisabledBorderBrush}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
