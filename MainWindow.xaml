                                              Sorting="ConfigGrid_Sorting"
                                              GridLinesVisibility="None">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="Конфиг" Width="300" SortMemberPath="ConfigName">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="10,1,4,1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding ConfigName}" Foreground="{DynamicResource MainTextBrush}" FontWeight="SemiBold" FontSize="12.4" />
                                                            <TextBlock Text="{Binding FileName}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10.4" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Доступно" Width="100" SortMemberPath="SortSuccessValue">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding SuccessCountText}" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Отклик" Width="76" SortMemberPath="AveragePingMilliseconds">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding ResponseText}" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Сводка" Width="*" SortMemberPath="Summary">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="6,0,2,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <DockPanel LastChildFill="True" Margin="0,0,4,0">
                                                                <controls:ProbeStatusBadge BadgeText="{Binding SummaryBadgeText}" Margin="0,0,8,0" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                                    <controls:ProbeStatusBadge.Style>
                                                                        <Style TargetType="controls:ProbeStatusBadge">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasProbeResult}" Value="False">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </controls:ProbeStatusBadge.Style>
                                                                </controls:ProbeStatusBadge>
                                                                <TextBlock Text="{Binding SummaryBodyText}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="0,0,2,0" />
                                                            </DockPanel>
                                                            <Button Grid.Column="1" Click="ProbeDetailsButton_Click" Tag="{Binding}" Margin="0,0,8,0" HorizontalAlignment="Right" VerticalAlignment="Center" ToolTip="Подробные результаты проверки">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource MiniIconButtonStyle}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <MultiDataTrigger>
                                                                                <MultiDataTrigger.Conditions>
                                                                                    <Condition Binding="{Binding HasProbeResult}" Value="True" />
                                                                                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver}" Value="True" />
                                                                                </MultiDataTrigger.Conditions>
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </MultiDataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                                <Path Width="12" Height="12" Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" StrokeThickness="1.45" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M 3 1.8 H 8.4 L 11.2 4.6 V 11.2 H 3 Z M 8.2 1.8 V 4.8 H 11.2 M 5.1 6.6 H 9.2 M 5.1 8.5 H 9.2" />
                                                            </Button>
                                                        </Grid>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>

                                <Grid Grid.Row="6" x:Name="TcpConfigGridPanel" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0"
                                            Background="{DynamicResource ActionBrush}"
                                            BorderBrush="{DynamicResource CardEdgeBrush}"
                                            BorderThickness="1,1,1,0"
                                            SnapsToDevicePixels="True">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="300" />
                                                <ColumnDefinition Width="54" />
                                                <ColumnDefinition Width="68" />
                                                <ColumnDefinition Width="54" />
                                                <ColumnDefinition Width="52" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" BorderBrush="{DynamicResource CardEdgeBrush}" BorderThickness="0,0,1,1">
                                                <TextBlock Text="Конфиг" Margin="12,8" Foreground="{DynamicResource MainTextBrush}" FontWeight="SemiBold" />
                                            </Border>
                                            <Border Grid.Column="1" BorderBrush="{DynamicResource CardEdgeBrush}" BorderThickness="0,0,1,1">
                                                <TextBlock Text="OK" Margin="0,8" HorizontalAlignment="Center" Foreground="{DynamicResource MainTextBrush}" FontWeight="SemiBold" />
                                            </Border>
                                            <Border Grid.Column="2" BorderBrush="{DynamicResource CardEdgeBrush}" BorderThickness="0,0,1,1">
                                                <TextBlock Text="Blocked" Margin="0,8" HorizontalAlignment="Center" Foreground="{DynamicResource MainTextBrush}" FontWeight="SemiBold" />
                                            </Border>
                                            <Border Grid.Column="3" BorderBrush="{DynamicResource CardEdgeBrush}" BorderThickness="0,0,1,1">
                                                <TextBlock Text="Fail" Margin="0,8" HorizontalAlignment="Center" Foreground="{DynamicResource MainTextBrush}" FontWeight="SemiBold" />
                                            </Border>
                                            <Border Grid.Column="4" BorderBrush="{DynamicResource CardEdgeBrush}" BorderThickness="0,0,1,1">
                                                <TextBlock Text="Unsup" Margin="0,8" HorizontalAlignment="Center" Foreground="{DynamicResource MainTextBrush}" FontWeight="SemiBold" />
                                            </Border>
                                            <Border Grid.Column="5" BorderBrush="{DynamicResource CardEdgeBrush}" BorderThickness="0,0,0,1">
                                                <TextBlock Text="Сводка" Margin="12,8" Foreground="{DynamicResource MainTextBrush}" FontWeight="SemiBold" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <DataGrid Grid.Row="1"
                                              x:Name="TcpConfigGrid"
                                              SelectionMode="Single"
                                              SelectionUnit="FullRow"
                                              CanUserResizeColumns="False"
                                              HeadersVisibility="None"
                                              BorderThickness="1,0,1,1"
                                              GridLinesVisibility="None">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Width="300">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="10,1,4,1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding ConfigName}" Foreground="{DynamicResource MainTextBrush}" FontWeight="SemiBold" FontSize="12.4" />
                                                            <TextBlock Text="{Binding FileName}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10.4" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Width="54">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding OkText}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Width="68">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding BlockedText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource ProbeBadgeFailureForegroundBrush}" FontWeight="SemiBold" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Width="54">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding FailText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource ProbeBadgePartialForegroundBrush}" FontWeight="SemiBold" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Width="52">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding UnsupportedText}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="6,0,2,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <DockPanel LastChildFill="True" Margin="0,0,4,0">
                                                                <DockPanel.Style>
                                                                    <Style TargetType="DockPanel">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasResult}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </DockPanel.Style>
                                                                <controls:ProbeStatusBadge BadgeText="{Binding SummaryBadgeText}" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                                <TextBlock Text="{Binding SummaryText}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                            </DockPanel>
                                                            <Button Grid.Column="1" Click="TcpDetailsButton_Click" Tag="{Binding}" Margin="0,0,8,0" HorizontalAlignment="Right" VerticalAlignment="Center" ToolTip="Подробные результаты TCP 16-20">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource MiniIconButtonStyle}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <MultiDataTrigger>
                                                                                <MultiDataTrigger.Conditions>
                                                                                    <Condition Binding="{Binding HasResult}" Value="True" />
                                                                                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver}" Value="True" />
                                                                                </MultiDataTrigger.Conditions>
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </MultiDataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                                <Path Width="12" Height="12" Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" StrokeThickness="1.45" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M 3 1.8 H 8.4 L 11.2 4.6 V 11.2 H 3 Z M 8.2 1.8 V 4.8 H 11.2 M 5.1 6.6 H 9.2 M 5.1 8.5 H 9.2" />
                                                            </Button>
                                                        </Grid>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Grid>
                    </TabItem>

                    <TabItem x:Name="InstallUpdatesTabItem" Style="{StaticResource SidebarTabItemStyle}">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource MdiPackageGeometry}"
                                      Style="{StaticResource SidebarIconPathStyle}"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" />
                                <TextBlock Text="Установка&#x0a;и обновление" Style="{StaticResource SidebarLabelTextStyle}" />
                            </StackPanel>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid Margin="14,12,14,14">
                                <Grid.Resources>
                                    <Style x:Key="InstallComponentTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleStyle}">
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="FontSize" Value="18" />
                                    </Style>
                                    <Style x:Key="InstallToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                        <Setter Property="Width" Value="154" />
                                        <Setter Property="Margin" Value="0" />
                                    </Style>
                                    <Style x:Key="InstallMoreButtonStyle" TargetType="Button" BasedOn="{StaticResource SquareActionButtonStyle}">
                                        <Setter Property="Width" Value="36" />
                                        <Setter Property="Height" Value="36" />
                                        <Setter Property="MinWidth" Value="36" />
                                        <Setter Property="FontSize" Value="16" />
                                        <Setter Property="Padding" Value="0" />
                                    </Style>
                                    <Style x:Key="InstallStateButtonStyle" TargetType="Button" BasedOn="{StaticResource InstallToolbarButtonStyle}" />
                                    <Style x:Key="ZapretStateButtonStyle" TargetType="Button" BasedOn="{StaticResource InstallStateButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasUpdate}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource SuccessBorderBrush}" />
                                                <Setter Property="Foreground" Value="#F7FFFC" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style x:Key="TgStateButtonStyle" TargetType="Button" BasedOn="{StaticResource InstallStateButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TgWsProxyHasUpdate}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource SuccessBorderBrush}" />
                                                <Setter Property="Foreground" Value="#F7FFFC" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style x:Key="ManagerStateButtonStyle" TargetType="Button" BasedOn="{StaticResource InstallStateButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasManagerUpdate}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource SuccessBorderBrush}" />
                                                <Setter Property="Foreground" Value="#F7FFFC" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style x:Key="InstallMetaLabelStyle" TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                        <Setter Property="FontSize" Value="12" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                    <Style x:Key="InstallMetaValueStyle" TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
                                        <Setter Property="FontSize" Value="12.5" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                    <Style x:Key="InstallPathTextStyle" TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
                                        <Setter Property="Margin" Value="0,6,0,0" />
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                        <Setter Property="MaxWidth" Value="760" />
                                    </Style>
                                    <Style x:Key="InstallStatusBadgeStyle" TargetType="Border">
                                        <Setter Property="Padding" Value="10,4" />
                                        <Setter Property="Margin" Value="6,0,0,0" />
                                        <Setter Property="CornerRadius" Value="8" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="Background" Value="{DynamicResource InstallAvailableBadgeBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource InstallAvailableBadgeBorderBrush}" />
                                        <Setter Property="TextElement.Foreground" Value="{DynamicResource InstallAvailableBadgeForegroundBrush}" />
                                        <Style.Triggers>
                                            <Trigger Property="Tag" Value="ok">
                                                <Setter Property="Background" Value="{DynamicResource SummarySuccessBadgeBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource SummarySuccessBadgeBorderBrush}" />
                                                <Setter Property="TextElement.Foreground" Value="{DynamicResource SummarySuccessBadgeIconBrush}" />
                                            </Trigger>
                                            <Trigger Property="Tag" Value="available">
                                                <Setter Property="Background" Value="{DynamicResource InstallAvailableBadgeBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource InstallAvailableBadgeBorderBrush}" />
                                                <Setter Property="TextElement.Foreground" Value="{DynamicResource InstallAvailableBadgeForegroundBrush}" />
                                            </Trigger>
                                            <Trigger Property="Tag" Value="unchecked">
                                                <Setter Property="Background" Value="{DynamicResource InstallAvailableBadgeBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource InstallAvailableBadgeBorderBrush}" />
                                                <Setter Property="TextElement.Foreground" Value="{DynamicResource InstallAvailableBadgeForegroundBrush}" />
                                            </Trigger>
                                            <Trigger Property="Tag" Value="missing">
                                                <Setter Property="Background" Value="{DynamicResource SummaryFailureBadgeBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource SummaryFailureBadgeBorderBrush}" />
                                                <Setter Property="TextElement.Foreground" Value="{DynamicResource SummaryFailureBadgeIconBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Resources>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource MdiPackageGeometry}"
                                                  Style="{StaticResource PageHeaderIconPathStyle}"
                                                  Fill="{DynamicResource AccentBorderBrush}"
                                                  Margin="0,0,10,0" />
                                            <TextBlock Text="Установка и обновление"
                                                       Style="{StaticResource PageHeaderTitleTextStyle}" />
                                        </StackPanel>
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="Управление компонентами, версиями и доступными обновлениями."
                                                   Style="{StaticResource PageHeaderDescriptionTextStyle}" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Width="208"
                                            Height="40"
                                            VerticalAlignment="Center"
                                            Command="{Binding CheckInstalledComponentUpdatesCommand}"
                                            Style="{StaticResource ActionButtonStyle}">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Path Data="{StaticResource MdiRefreshGeometry}"
                                                  Style="{StaticResource ButtonIconPathStyle}"
                                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  Margin="0,0,6,0" />
