                                                    <Path Grid.Column="3"
                                                          Data="{StaticResource MdiChevronRightGeometry}"
                                                          Style="{StaticResource AccentIconPathStyle}"
                                                          Fill="{DynamicResource TextMutedBrush}"
                                                          VerticalAlignment="Center" />
                                                </Grid>
                                            </Button>

                                            <TextBlock Margin="0,12,0,0"
                                                       Text="Режимы отличаются способом запуска и набором задействованных компонентов."
                                                       Style="{StaticResource HomeBodyTextStyle}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem x:Name="ConfigsTabItem" Style="{StaticResource SidebarTabItemStyle}">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource MdiListBulletedGeometry}"
                                      Style="{StaticResource SidebarIconPathStyle}"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" />
                                <TextBlock Text="Конфиги" Style="{StaticResource SidebarLabelTextStyle}" />
                            </StackPanel>
                        </TabItem.Header>
                        <Grid Margin="14,12,14,14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

