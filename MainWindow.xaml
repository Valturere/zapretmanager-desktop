                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="12" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0"
                                                            Width="40"
                                                            Height="40"
                                                            CornerRadius="12"
                                                            Background="{DynamicResource CardBrush}"
                                                            BorderBrush="{DynamicResource AccentBorderBrush}"
                                                            BorderThickness="1">
                                                        <Path Data="{StaticResource MdiTelegramGeometry}"
                                                              Style="{StaticResource AccentIconPathStyle}"
                                                              Fill="{DynamicResource AccentBorderBrush}"
                                                              Margin="1,0,0,0"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                                    </Border>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Автоматический режим (TG WS Proxy)"
                                                                   Foreground="{DynamicResource MainTextBrush}"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold" />
