                                <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="NavItem" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="NavItem" Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
                                <Setter Property="Foreground" Value="#F7FBFF" />
