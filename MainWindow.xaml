                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <Path Data="{StaticResource MdiEyeOffGeometry}"
                                                          Style="{StaticResource ButtonIconPathStyle}"
                                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          Margin="0,1,8,0"
                                                          VerticalAlignment="Center" />
                                                    <TextBlock Text="Скрыть"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="6" x:Name="RegularConfigGridPanel">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0"
                                            Background="{DynamicResource ActionBrush}"
                                            BorderBrush="{DynamicResource CardEdgeBrush}"
                                            BorderThickness="1,1,1,0"
                                            SnapsToDevicePixels="True">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="300" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="76" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" BorderBrush="{DynamicResource CardEdgeBrush}" BorderThickness="0,0,1,1">
                                                <Button Content="Конфиг" Tag="ConfigName" Click="ConfigHeaderSortButton_Click" Style="{StaticResource ConfigHeaderButtonStyle}" />
                                            </Border>
                                            <Border Grid.Column="1" BorderBrush="{DynamicResource CardEdgeBrush}" BorderThickness="0,0,1,1">
                                                <Button Content="Доступно" Tag="SortSuccessValue" Click="ConfigHeaderSortButton_Click" HorizontalContentAlignment="Center" Style="{StaticResource ConfigHeaderButtonStyle}" />
                                            </Border>
                                            <Border Grid.Column="2" BorderBrush="{DynamicResource CardEdgeBrush}" BorderThickness="0,0,1,1">
                                                <Button Content="Отклик" Tag="AveragePingMilliseconds" Click="ConfigHeaderSortButton_Click" HorizontalContentAlignment="Center" Style="{StaticResource ConfigHeaderButtonStyle}" />
                                            </Border>
                                            <Border Grid.Column="3" BorderBrush="{DynamicResource CardEdgeBrush}" BorderThickness="0,0,0,1">
