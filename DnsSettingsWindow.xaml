<Window x:Class="ZapretManager.DnsSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройка DNS-адреса"
        Width="520"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="Transparent">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBgBrush" Color="#102235" />
        <SolidColorBrush x:Key="WindowBorderBrush" Color="#295276" />
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="MutedBrush" Color="#A7BBD1" />
        <SolidColorBrush x:Key="InputBrush" Color="#0A1725" />
        <SolidColorBrush x:Key="InputBorderBrush" Color="#2D5379" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#47C78B" />
        <SolidColorBrush x:Key="PrimaryBorderBrush" Color="#7BE2B2" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#0A2416" />
        <SolidColorBrush x:Key="ActionBrush" Color="#173454" />
        <SolidColorBrush x:Key="ActionBorderBrush" Color="#31597F" />
        <SolidColorBrush x:Key="DisabledBrush" Color="#13283F" />
        <SolidColorBrush x:Key="DisabledTextBrush" Color="#8EA6C2" />

        <Style TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource ActionBorderBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryBorderBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ScrollBarButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Width" Value="4" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   Orientation="{TemplateBinding Orientation}"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarButtonStyle}"
                                                  Command="ScrollBar.PageUpCommand" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Margin="0" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarButtonStyle}"
                                                  Command="ScrollBar.PageDownCommand" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="4" />
                                <Setter Property="Width" Value="Auto" />
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChromeButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style x:Key="ComboToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent"
                                CornerRadius="6" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Height" Value="36" />
        </Style>

        <Style x:Key="DialogToggleCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource ActionBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ActionBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="OuterBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ContentPresenter VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />

                                <Grid Grid.Column="1"
                                      Width="44"
                                      Height="24"
                                      Margin="12,0,0,0"
                                      VerticalAlignment="Center"
                                      IsHitTestVisible="False">
                                    <Border x:Name="ToggleTrack"
                                            Background="{DynamicResource DisabledBrush}"
                                            BorderBrush="{DynamicResource InputBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12" />
                                    <Ellipse x:Name="ToggleThumb"
                                             Width="18"
                                             Height="18"
                                             Margin="3,0,0,0"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Center"
                                             Fill="{DynamicResource TextBrush}" />
                                </Grid>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleTrack" Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                <Setter TargetName="ToggleTrack" Property="BorderBrush" Value="{DynamicResource PrimaryBorderBrush}" />
                                <Setter TargetName="ToggleThumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="ToggleThumb" Property="Margin" Value="0,0,3,0" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="Opacity" Value="0.96" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="OuterBorder" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    ClipToBounds="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="34" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton Grid.ColumnSpan="2"
                                                  ClickMode="Press"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Style="{StaticResource ComboToggleButtonStyle}"
                                                  Background="Transparent"
                                                  BorderBrush="Transparent"
                                                  BorderThickness="0" />
                                    <TextBlock Grid.Column="0"
                                               Margin="10,0,8,0"
                                               VerticalAlignment="Center"
                                               Text="{Binding Path=SelectedItem.Label, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=''}"
                                               Foreground="{TemplateBinding Foreground}"
                                               TextTrimming="CharacterEllipsis"
                                               IsHitTestVisible="False" />
                                    <Border Grid.Column="1"
                                            x:Name="DropDownBorder"
                                            Background="{DynamicResource DisabledBrush}"
                                            BorderBrush="{DynamicResource InputBorderBrush}"
                                            BorderThickness="1,0,0,0"
                                            CornerRadius="0,5,5,0"
                                            IsHitTestVisible="False">
                                        <Path Width="10"
                                              Height="6"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Fill="{DynamicResource TextBrush}"
                                              Data="M 0 0 L 10 0 L 5 6 Z" />
                                    </Border>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border Margin="0,4,0,0"
                                        Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="{DynamicResource WindowBgBrush}"
                                        BorderBrush="{DynamicResource InputBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="220"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DropDownBorder" Property="Background" Value="{DynamicResource ActionBrush}" />
                                <Setter TargetName="DropDownBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource DisabledBrush}" />
                                <Setter TargetName="DropDownBorder" Property="Background" Value="{DynamicResource DisabledBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource WindowBgBrush}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Margin="0"
                                Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollContentPresenter}}"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ActionBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ActionBorderBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="1"
            Padding="18"
            Background="{DynamicResource WindowBgBrush}"
            BorderBrush="{DynamicResource WindowBorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Настройка DNS-адреса"
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="18"
                           FontWeight="SemiBold" />
                <Button Grid.Column="1"
                        Width="30"
                        Height="30"
                        Margin="12,0,0,0"
                        Click="CloseButton_Click"
                        Content="×"
                        FontSize="18"
                        Cursor="Hand"
                        Style="{StaticResource ChromeButtonStyle}" />
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,16,0,0">
                <TextBlock Margin="0,0,0,6"
                           Foreground="{DynamicResource TextBrush}"
                           FontWeight="SemiBold"
                           Text="Профиль DNS" />
                <ComboBox x:Name="ProfileComboBox"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Key"
                          SelectionChanged="ProfileComboBox_SelectionChanged" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="{DynamicResource MutedBrush}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Text="Если предложенный DNS не подошёл, здесь можно вручную выбрать другой профиль или задать свои DNS-адреса и DoH URL." />

                <Grid x:Name="DnsInputsGrid" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Foreground="{DynamicResource TextBrush}"
                                   FontWeight="SemiBold"
                                   Text="Основной DNS" />
                        <TextBox x:Name="PrimaryDnsTextBox"
                                 Margin="0,6,0,0"
                                 Style="{StaticResource InputTextBoxStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Foreground="{DynamicResource TextBrush}"
                                   FontWeight="SemiBold"
                                   Text="Дополнительный DNS" />
                        <TextBox x:Name="SecondaryDnsTextBox"
                                 Margin="0,6,0,0"
                                 Style="{StaticResource InputTextBoxStyle}" />
                    </StackPanel>
                </Grid>

                <CheckBox x:Name="UseDohCheckBox"
                          Margin="0,14,0,0"
                          Content="DNS-over-HTTPS (DoH)"
                          Checked="UseDohCheckBox_Changed"
                          Unchecked="UseDohCheckBox_Changed"
                          Style="{StaticResource DialogToggleCheckBoxStyle}" />

                <StackPanel x:Name="DohTemplatePanel" Margin="0,14,0,0">
                    <TextBlock Foreground="{DynamicResource TextBrush}"
                               FontWeight="SemiBold"
                               Text="DoH URL" />
                    <TextBox x:Name="DohTemplateTextBox"
                             Margin="0,6,0,0"
                             Style="{StaticResource InputTextBoxStyle}" />
                </StackPanel>

            </StackPanel>

            <UniformGrid Grid.Row="2"
                         Margin="0,18,0,0"
                         Columns="2">
                <Button x:Name="ApplyButton"
                        Content="Применить"
                        Click="ApplyButton_Click"
                        Margin="0,0,8,0"
                        Height="36"
                        Background="{DynamicResource PrimaryBrush}"
                        BorderBrush="{DynamicResource PrimaryBorderBrush}"
                        Foreground="{DynamicResource PrimaryTextBrush}"
                        Style="{StaticResource DialogButtonStyle}" />
                <Button x:Name="CloseDialogButton"
                        Content="Закрыть"
                        Click="CloseButton_Click"
                        Height="36"
                        Background="{DynamicResource ActionBrush}"
                        BorderBrush="{DynamicResource ActionBorderBrush}"
                        Foreground="{DynamicResource TextBrush}"
                        Style="{StaticResource DialogButtonStyle}" />
            </UniformGrid>
        </Grid>
    </Border>
</Window>
