<Window x:Class="ZapretManager.AllowDomainsImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Импорт из allow-domains"
        Width="560"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBgBrush" Color="#102235" />
        <SolidColorBrush x:Key="WindowBorderBrush" Color="#295276" />
        <SolidColorBrush x:Key="TitleBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextBrush" Color="#D5E4F5" />
        <SolidColorBrush x:Key="MutedBrush" Color="#89A6C2" />
        <SolidColorBrush x:Key="InputBrush" Color="#0A1725" />
        <SolidColorBrush x:Key="InputBorderBrush" Color="#2D5379" />
        <SolidColorBrush x:Key="ActionBrush" Color="#173454" />
        <SolidColorBrush x:Key="ActionBorderBrush" Color="#31597F" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#47C78B" />
        <SolidColorBrush x:Key="PrimaryBorderBrush" Color="#7BE2B2" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#0A2416" />
        <SolidColorBrush x:Key="SelectionBrush" Color="#183149" />

        <Style TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource ActionBorderBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryBorderBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ScrollBarButtonStyle" TargetType="RepeatButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Width" Value="4" />
            <Setter Property="Margin" Value="2,0,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   Orientation="{TemplateBinding Orientation}"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarButtonStyle}" Command="ScrollBar.LineUpCommand" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Margin="0" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarButtonStyle}" Command="ScrollBar.LineDownCommand" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="4" />
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Margin" Value="0,2,0,0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="CheckBorder"
                                    Width="18"
                                    Height="18"
                                    CornerRadius="4"
                                    Background="{DynamicResource InputBrush}"
                                    BorderBrush="{DynamicResource InputBorderBrush}"
                                    BorderThickness="1" />
                            <Ellipse x:Name="CheckDot"
                                     Width="8"
                                     Height="8"
                                     Fill="{DynamicResource PrimaryBrush}"
                                     Visibility="Collapsed"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
                            <ContentPresenter Grid.Column="2"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBorderBrush}" />
                                <Setter TargetName="CheckDot" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="{DynamicResource SelectionBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="1"
            Padding="18"
            Background="{DynamicResource WindowBgBrush}"
            BorderBrush="{DynamicResource WindowBorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Готовые списки доменов"
                           Foreground="{DynamicResource TitleBrush}"
                           FontSize="18"
                           FontWeight="SemiBold" />
                <Button Grid.Column="1"
                        Width="30"
                        Height="30"
                        Margin="12,0,0,0"
                        Click="CloseButton_Click"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Foreground="{DynamicResource TitleBrush}"
                        Cursor="Hand">
                    <Path Data="M13.46 12L19 17.54V19h-1.46L12 13.46L6.46 19H5v-1.46L10.54 12L5 6.46V5h1.46L12 10.54L17.54 5H19v1.46z"
                          Width="14"
                          Height="14"
                          Stretch="Uniform"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Button>
            </Grid>

            <TextBlock Grid.Row="1"
                       Margin="0,14,0,0"
                       Foreground="{DynamicResource MutedBrush}"
                       FontSize="13.5"
                       TextWrapping="Wrap"
                       LineHeight="21"
                       Text="Выберите один или несколько готовых списков. Менеджер добавит/очистит домены сразу в текущем списке и не затронет остальные строки." />

            <StackPanel Grid.Row="2" Margin="0,18,0,0">
                <CheckBox x:Name="SelectAllCheckBox"
                          Content="Выбрать всё"
                          Checked="SelectAllCheckBox_Checked"
                          Unchecked="SelectAllCheckBox_Unchecked" />
                <TextBlock x:Name="SelectionSummaryTextBlock"
                           Margin="0,10,0,0"
                           Foreground="{DynamicResource MutedBrush}"
                           FontSize="12.8" />
            </StackPanel>

            <Border Grid.Row="3"
                    Margin="0,16,0,0"
                    Padding="12"
                    Background="{DynamicResource InputBrush}"
                    BorderBrush="{DynamicResource InputBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              MaxHeight="340">
                    <Border Margin="0,0,4,0"
                            Background="Transparent">
                        <ItemsControl x:Name="PresetItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="10,8"
                                            Background="{DynamicResource WindowBgBrush}"
                                            BorderBrush="{DynamicResource InputBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <CheckBox Content="{Binding Label}"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Checked="PresetCheckBox_Changed"
                                                  Unchecked="PresetCheckBox_Changed" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </ScrollViewer>
            </Border>

            <StackPanel Grid.Row="4"
                        Margin="0,20,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Width="132"
                        Height="36"
                        Margin="0,0,10,0"
                        Click="CancelButton_Click"
                        Content="Закрыть"
                        Foreground="{DynamicResource TitleBrush}"
                        Background="{DynamicResource ActionBrush}"
                        BorderBrush="{DynamicResource ActionBorderBrush}"
                        BorderThickness="1"
                        Cursor="Hand"
                        Style="{StaticResource ActionButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
