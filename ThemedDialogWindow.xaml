<Window x:Class="ZapretManager.ThemedDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zapret Manager"
        Width="520"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <SolidColorBrush x:Key="DialogBackgroundBrush" Color="#102235" />
        <SolidColorBrush x:Key="DialogBorderBrush" Color="#295276" />
        <SolidColorBrush x:Key="DialogTitleBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="DialogTextBrush" Color="#D5E4F5" />
        <SolidColorBrush x:Key="DialogMutedBrush" Color="#89A6C2" />
        <SolidColorBrush x:Key="DialogActionBrush" Color="#173454" />
        <SolidColorBrush x:Key="DialogActionBorderBrush" Color="#31597F" />
        <SolidColorBrush x:Key="DialogPrimaryBrush" Color="#47C78B" />
        <SolidColorBrush x:Key="DialogPrimaryBorderBrush" Color="#7BE2B2" />
        <SolidColorBrush x:Key="DialogPrimaryTextBrush" Color="#0A2416" />
        <SolidColorBrush x:Key="DialogPanelBrush" Color="#0C1A28" />
        <SolidColorBrush x:Key="DialogPanelBorderBrush" Color="#274A6B" />
        <Geometry x:Key="DialogInfoGeometry">M11 9h2V7h-2m1 13c-4.41 0-8-3.59-8-8s3.59-8 8-8s8 3.59 8 8s-3.59 8-8 8m0-18A10 10 0 0 0 2 12a10 10 0 0 0 10 10a10 10 0 0 0 10-10A10 10 0 0 0 12 2m-1 15h2v-6h-2z</Geometry>
        <Geometry x:Key="DialogHelpGeometry">M10 17h2v-2h-2m1-13A10 10 0 0 0 2 12a10 10 0 0 0 10 10a10 10 0 0 0 10-10A10 10 0 0 0 12 2m0 18a8 8 0 0 1-8-8a8 8 0 0 1 8-8a8 8 0 0 1 8 8a8 8 0 0 1-8 8m0-14a4 4 0 0 0-4 4h2a2 2 0 0 1 4 0c0 2-3 1.75-3 5h2c0-2.25 3-2.5 3-5a4 4 0 0 0-4-4z</Geometry>
        <Geometry x:Key="DialogAlertGeometry">M11 15h2v2h-2zm0-8h2v6h-2zm1-5C6.47 2 2 6.5 2 12a10 10 0 0 0 10 10a10 10 0 0 0 10-10A10 10 0 0 0 12 2m0 18a8 8 0 0 1-8-8a8 8 0 0 1 8-8a8 8 0 0 1 8 8a8 8 0 0 1-8 8</Geometry>
        <Geometry x:Key="DialogCloseGeometry">M13.46 12L19 17.54V19h-1.46L12 13.46L6.46 19H5v-1.46L10.54 12L5 6.46V5h1.46L12 10.54L17.54 5H19v1.46z</Geometry>
        <Style x:Key="DialogActionButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DialogChromeButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogActionButtonStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource DialogTitleBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DialogActionBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Border Margin="1"
            Padding="18"
            Background="{DynamicResource DialogBackgroundBrush}"
            BorderBrush="{DynamicResource DialogBorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24"
                              ShadowDepth="0"
                              Opacity="0.18"
                              Color="#172838" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.Resources>
                <Style TargetType="CheckBox">
                    <Setter Property="Foreground" Value="{DynamicResource DialogTextBrush}" />
                    <Setter Property="FontSize" Value="13" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="CheckBox">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="CheckBorder"
                                            Width="18"
                                            Height="18"
                                            CornerRadius="4"
                                            Background="{DynamicResource DialogActionBrush}"
                                            BorderBrush="{DynamicResource DialogActionBorderBrush}"
                                            BorderThickness="1" />
                                    <Path x:Name="CheckMark"
                                          Width="10"
                                          Height="7"
                                          Data="M 1 3.5 L 4 6.5 L 9 1"
                                          Stroke="{DynamicResource DialogPrimaryTextBrush}"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Visibility="Collapsed"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                                    <ContentPresenter Grid.Column="2"
                                                      VerticalAlignment="Center"
                                                      RecognizesAccessKey="True" />
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="CheckBorder" Property="Background" Value="{DynamicResource DialogPrimaryBrush}" />
                                        <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{DynamicResource DialogPrimaryBorderBrush}" />
                                        <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Grid.Resources>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="34"
                        Height="34"
                        Background="{DynamicResource DialogPrimaryBrush}"
                        BorderBrush="{DynamicResource DialogPrimaryBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <Path x:Name="StatusGlyphPath"
                          Width="18"
                          Height="18"
                          Stretch="Uniform"
                          Fill="{DynamicResource DialogPrimaryTextBrush}"
                          Data="{StaticResource DialogInfoGeometry}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                        <Path.Style>
                            <Style TargetType="Path">
                                <Setter Property="Data" Value="{StaticResource DialogInfoGeometry}" />
                                <Style.Triggers>
                                    <Trigger Property="Tag" Value="error">
                                        <Setter Property="Data" Value="{StaticResource DialogAlertGeometry}" />
                                    </Trigger>
                                    <Trigger Property="Tag" Value="question">
                                        <Setter Property="Data" Value="{StaticResource DialogHelpGeometry}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Border>
                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="TitleTextBlock"
                               Foreground="{DynamicResource DialogTitleBrush}"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="SubtitleTextBlock"
                               Margin="0,3,0,0"
                               Foreground="{DynamicResource DialogMutedBrush}"
                               FontSize="12.5"
                               Text="Результат операции" />
                </StackPanel>
                <Button Grid.Column="3"
                        Width="30"
                        Height="30"
                        Margin="12,0,0,0"
                        Click="CloseButton_Click"
                        Style="{StaticResource DialogChromeButtonStyle}"
                        Cursor="Hand">
                    <Path Data="{StaticResource DialogCloseGeometry}"
                          Width="14"
                          Height="14"
                          Stretch="Uniform"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Button>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,16,0,0"
                    Padding="16"
                    Background="{DynamicResource DialogPanelBrush}"
                    BorderBrush="{DynamicResource DialogPanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <TextBlock x:Name="MessageTextBlock"
                           Foreground="{DynamicResource DialogTextBrush}"
                           FontSize="13.5"
                           TextWrapping="Wrap"
                           LineHeight="22" />
            </Border>

            <CheckBox x:Name="RememberCheckBox"
                      Grid.Row="2"
                      Margin="0,16,0,0"
                      Visibility="Collapsed"
                      Content="Больше не спрашивать" />

            <StackPanel x:Name="ButtonsPanel"
                        Grid.Row="3"
                        Margin="0,18,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="TertiaryButton"
                        Width="124"
                        Height="34"
                        Margin="0,0,10,0"
                        Click="TertiaryButton_Click"
                        Content="Отмена"
                        Foreground="{DynamicResource DialogTitleBrush}"
                        Background="{DynamicResource DialogActionBrush}"
                        BorderBrush="{DynamicResource DialogActionBorderBrush}"
                        BorderThickness="1"
                        Cursor="Hand"
                        Visibility="Collapsed"
                        Style="{StaticResource DialogActionButtonStyle}" />
                <Button x:Name="SecondaryButton"
                        Width="112"
                        Height="34"
                        Margin="0,0,10,0"
                        Click="SecondaryButton_Click"
                        Content="Нет"
                        Foreground="{DynamicResource DialogTitleBrush}"
                        Background="{DynamicResource DialogActionBrush}"
                        BorderBrush="{DynamicResource DialogActionBorderBrush}"
                        BorderThickness="1"
                        Cursor="Hand"
                        Style="{StaticResource DialogActionButtonStyle}" />
                <Button x:Name="PrimaryButton"
                        Width="112"
                        Height="34"
                        Click="PrimaryButton_Click"
                        Content="Закрыть"
                        Foreground="{DynamicResource DialogPrimaryTextBrush}"
                        Background="{DynamicResource DialogPrimaryBrush}"
                        BorderBrush="{DynamicResource DialogPrimaryBorderBrush}"
                        BorderThickness="1"
                        Cursor="Hand"
                        Style="{StaticResource DialogActionButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
