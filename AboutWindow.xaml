<Window x:Class="ZapretManager.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="О программе"
        Width="560"
        Height="356"
        MinWidth="520"
        MinHeight="336"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBgBrush" Color="#102235" />
        <SolidColorBrush x:Key="WindowBorderBrush" Color="#295276" />
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="MutedBrush" Color="#9AB2CD" />
        <SolidColorBrush x:Key="PanelBrush" Color="#0C1A28" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#274A6B" />
        <SolidColorBrush x:Key="ActionBrush" Color="#173454" />
        <SolidColorBrush x:Key="ActionBorderBrush" Color="#31597F" />
        <SolidColorBrush x:Key="LinkBrush" Color="#7BC8FF" />
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="132" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource ActionBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ActionBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.92" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.85" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ChromeButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Width" Value="30" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Content" Value="×" />
        </Style>
    </Window.Resources>

    <Border Margin="1"
            Padding="18"
            Background="{DynamicResource WindowBgBrush}"
            BorderBrush="{DynamicResource WindowBorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="О программе"
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />

                <Button Grid.Column="1"
                        Style="{StaticResource ChromeButtonStyle}"
                        Click="CloseButton_Click" />
            </Grid>

            <TextBlock Grid.Row="1"
                       Margin="0,12,0,0"
                       Text="Менеджер для установки, обновления, запуска и проверки сборки zapret."
                       Foreground="{DynamicResource MutedBrush}"
                       FontSize="13.5"
                       TextWrapping="Wrap" />

            <Border Grid.Row="2"
                    Margin="0,18,0,0"
                    Padding="16"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Название"
                               Foreground="{DynamicResource MutedBrush}"
                               FontSize="12.8" />
                    <TextBlock Grid.Column="1"
                               Text="ZapretManager"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="12.8"
                               FontWeight="Medium" />

                    <TextBlock Grid.Row="1"
                               Margin="0,12,0,0"
                               Text="Версия"
                               Foreground="{DynamicResource MutedBrush}"
                               FontSize="12.8" />
                    <TextBlock x:Name="VersionTextBlock"
                               Grid.Row="1"
                               Grid.Column="1"
                               Margin="0,12,0,0"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="12.8"
                               FontWeight="Medium" />

                    <TextBlock x:Name="AuthorGitHubLabelTextBlock"
                               Grid.Row="2"
                               Margin="0,12,0,0"
                               Text="Автор программы"
                               Foreground="{DynamicResource MutedBrush}"
                               FontSize="12.8" />
                    <TextBlock x:Name="AuthorGitHubTextBlock"
                               Grid.Row="2"
                               Grid.Column="1"
                               Margin="0,12,0,0"
                               Foreground="{DynamicResource LinkBrush}"
                               FontSize="12.8"
                               FontWeight="Medium">
                        <Hyperlink x:Name="AuthorGitHubHyperlink"
                                   Click="AuthorGitHubHyperlink_Click">
                            <Run x:Name="AuthorGitHubRun" />
                        </Hyperlink>
                    </TextBlock>

                    <TextBlock Grid.Row="3"
                               Margin="0,12,0,0"
                               Text="Основа сборки"
                               Foreground="{DynamicResource MutedBrush}"
                               FontSize="12.8" />
                    <TextBlock Grid.Row="3"
                               Grid.Column="1"
                               Margin="0,12,0,0"
                               Foreground="{DynamicResource LinkBrush}"
                               FontSize="12.8"
                               FontWeight="Medium">
                        <Hyperlink x:Name="FlowsealRepositoryHyperlink"
                                   Click="FlowsealRepositoryHyperlink_Click">
                            <Run x:Name="FlowsealRepositoryRun" />
                        </Hyperlink>
                    </TextBlock>

                    <TextBlock Grid.Row="4"
                               Margin="0,12,0,0"
                               Text="Проект zapret"
                               Foreground="{DynamicResource MutedBrush}"
                               FontSize="12.8" />
                    <TextBlock Grid.Row="4"
                               Grid.Column="1"
                               Margin="0,12,0,0"
                               Foreground="{DynamicResource LinkBrush}"
                               FontSize="12.8"
                               FontWeight="Medium">
                        <Hyperlink x:Name="ZapretRepositoryHyperlink"
                                   Click="ZapretRepositoryHyperlink_Click">
                            <Run x:Name="ZapretRepositoryRun" />
                        </Hyperlink>
                    </TextBlock>
                </Grid>
            </Border>

            <StackPanel Grid.Row="3"
                        Margin="0,18,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Закрыть"
                        Style="{StaticResource ActionButtonStyle}"
                        Click="CloseButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
