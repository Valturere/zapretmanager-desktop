<Window x:Class="ZapretManager.ListEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактор списка"
        Width="760"
        Height="620"
        MinWidth="640"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowsTransparency="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBgBrush" Color="#102235" />
        <SolidColorBrush x:Key="WindowBorderBrush" Color="#295276" />
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="MutedBrush" Color="#A7BBD1" />
        <SolidColorBrush x:Key="PanelBrush" Color="#0C1A28" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#2C5478" />
        <SolidColorBrush x:Key="InputBrush" Color="#0A1725" />
        <SolidColorBrush x:Key="InputBorderBrush" Color="#2D5379" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#47C78B" />
        <SolidColorBrush x:Key="PrimaryBorderBrush" Color="#7BE2B2" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#0A2416" />
        <SolidColorBrush x:Key="ActionBrush" Color="#173454" />
        <SolidColorBrush x:Key="ActionBorderBrush" Color="#31597F" />

        <Style TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource ActionBorderBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryBorderBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ScrollBarButtonStyle" TargetType="RepeatButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Width" Value="4" />
            <Setter Property="Margin" Value="2,0,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   Orientation="{TemplateBinding Orientation}"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarButtonStyle}" Command="ScrollBar.LineUpCommand" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Margin="0" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarButtonStyle}" Command="ScrollBar.LineDownCommand" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="4" />
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Margin" Value="0,2,0,0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="126" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="FontSize" Value="12.5" />
        </Style>
    </Window.Resources>

    <Border Margin="1"
            Padding="18"
            Background="{DynamicResource WindowBgBrush}"
            BorderBrush="{DynamicResource WindowBorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TitleTextBlock"
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="18"
                           FontWeight="SemiBold" />
                <Button Grid.Column="1"
                        Width="30"
                        Height="30"
                        Margin="12,0,0,0"
                        Click="CloseButton_Click"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Foreground="{DynamicResource TextBrush}"
                        Content="×"
                        FontSize="18"
                        Cursor="Hand" />
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,14,0,14"
                    Padding="12"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="DescriptionTextBlock"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="13.5"
                               TextWrapping="Wrap"
                               LineHeight="21" />
                    <Grid Grid.Row="1"
                          Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="CountTextBlock"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource MutedBrush}"
                                   FontSize="13" />
                        <Button x:Name="ImportAllowDomainsButton"
                                Grid.Column="1"
                                Margin="12,0,0,0"
                                HorizontalAlignment="Right"
                                MinWidth="150"
                                Content="Импорт списков"
                                Click="ImportAllowDomainsButton_Click"
                                Background="{DynamicResource ActionBrush}"
                                BorderBrush="{DynamicResource ActionBorderBrush}"
                                Foreground="{DynamicResource TextBrush}"
                                Style="{StaticResource SmallActionButtonStyle}"
                                Visibility="Collapsed" />
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <TextBox x:Name="EditorTextBox"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextChanged="EditorTextBox_TextChanged"
                         Foreground="{DynamicResource TextBrush}"
                         Background="{DynamicResource InputBrush}"
                         BorderBrush="{DynamicResource InputBorderBrush}"
                         BorderThickness="1"
                         FontSize="14"
                         Padding="14"
                         TextWrapping="NoWrap"
                         FontFamily="Consolas" />
                <TextBlock x:Name="PlaceholderTextBlock"
                           Margin="16,14,0,0"
                           Foreground="{DynamicResource MutedBrush}"
                           FontSize="13.5"
                           IsHitTestVisible="False"
                           TextWrapping="Wrap" />
            </Grid>

            <UniformGrid Grid.Row="3"
                         Margin="0,16,0,0"
                         Columns="4">
                <Button Content="Сохранить"
                        Click="SaveButton_Click"
                        Margin="0,0,8,0"
                        Background="{DynamicResource PrimaryBrush}"
                        BorderBrush="{DynamicResource PrimaryBorderBrush}"
                        Foreground="{DynamicResource PrimaryTextBrush}"
                        Style="{StaticResource DialogButtonStyle}" />
                <Button Content="Очистить"
                        Click="ClearButton_Click"
                        Margin="0,0,8,0"
                        Background="#B54848"
                        BorderBrush="#D96A6A"
                        Foreground="White"
                        Style="{StaticResource DialogButtonStyle}" />
                <Button x:Name="ResetToDefaultButton"
                        Content="По умолчанию"
                        Click="ResetToDefaultButton_Click"
                        Margin="0,0,8,0"
                        Background="{DynamicResource ActionBrush}"
                        BorderBrush="{DynamicResource ActionBorderBrush}"
                        Foreground="{DynamicResource TextBrush}"
                        Style="{StaticResource DialogButtonStyle}"
                        Visibility="Collapsed" />
                <Button Content="Закрыть"
                        Click="CloseButton_Click"
                        Background="{DynamicResource ActionBrush}"
                        BorderBrush="{DynamicResource ActionBorderBrush}"
                        Foreground="{DynamicResource TextBrush}"
                        Style="{StaticResource DialogButtonStyle}" />
            </UniformGrid>
        </Grid>
    </Border>
</Window>
